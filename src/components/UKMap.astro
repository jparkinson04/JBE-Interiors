---
/* Country outlines from Natural Earth 110m (public domain), projected to a
   400x600 viewBox with cosine-corrected equirectangular projection at
   mean latitude 55°N. The viewBox is displayed cropped (y=100 to y=600)
   so the top of the dataset's empty space (where Shetland would sit) is
   trimmed and the section sits tighter on the page. Jersey isn't in the
   110m dataset so it's added manually at its known coordinates. */
const UK_PATH =
  'M150.9,354.4L129.0,344.5L111.1,345.1L117.1,319.4L111.1,293.7L135.4,291.7L166.4,321.4L150.9,354.4ZM243.2,125.5L212.3,177.5L241.8,170.9L273.5,171.1L265.9,210.2L239.9,253.3L269.8,256.3L272.1,261.4L297.9,318.0L317.7,325.7L335.5,380.4L343.7,399.4L378.8,408.5L375.3,439.2L360.5,453.3L372.1,478.1L346.1,503.2L307.4,502.8L258.1,516.0L244.6,506.5L225.5,529.0L198.8,523.6L178.5,541.9L163.1,532.3L205.5,481.9L231.4,471.6L231.2,471.5L186.0,463.5L177.8,444.4L208.0,429.5L192.2,403.7L197.7,372.2L240.7,376.6L240.7,376.6L245.0,348.7L225.6,319.2L225.2,318.5L190.0,310.0L183.2,297.0L193.7,275.6L184.2,262.4L168.6,285.1L166.9,238.8L152.3,214.3L162.8,164.7L185.2,125.8L208.3,129.6L243.2,125.5Z';
const IRELAND_PATH =
  'M111.1,293.7L117.1,319.4L111.1,345.1L129.0,344.5L150.9,354.4L155.7,388.6L133.8,431.5L82.5,459.9L41.6,452.6L65.0,402.5L49.9,353.7L89.3,316.1L111.1,293.7Z';

interface Pin {
  /* Pre-projected viewBox coords (0–400 horizontal, 0–600 vertical) */
  x: number;
  y: number;
  /* Location label shown in the tooltip on hover */
  primary: string;
  /* Whether to flip the tooltip to the left so it doesn't clip the edge */
  flip?: 'left' | 'right';
  /* If true, the visible dot is drawn inside the SVG (used for Jersey
     so the dot can share coordinates with the island ellipse exactly).
     The HTML overlay still handles hover/tooltip. */
  svgDot?: boolean;
}

/* Every location JBE Interiors has been mentioned working in.
   Sorted north-to-south so the DOM order matches the visual
   sequence (drives the staggered pulse-ring rhythm).
   Pins on the right-hand side of the map flip their tooltip to the
   left so it doesn't clip the panel edge. */
const pins: Pin[] = [
  { x: 244.2, y: 229.8, primary: 'Dundee' },
  { x: 237.9, y: 254.2, primary: 'Edinburgh' },
  { x: 207.2, y: 258.5, primary: 'Glasgow' },
  { x: 283.4, y: 301.0, primary: 'Newcastle' },
  { x: 158.6, y: 319.3, primary: 'Belfast' },
  { x: 288.1, y: 357.7, primary: 'Leeds' },
  { x: 320.7, y: 359.2, primary: 'Hull', flip: 'left' },
  { x: 252.0, y: 359.5, primary: 'Preston' },
  { x: 297.5, y: 370.9, primary: 'Doncaster' },
  { x: 265.3, y: 372.9, primary: 'Manchester' },
  { x: 287.6, y: 377.7, primary: 'Sheffield' },
  { x: 247.7, y: 379.7, primary: 'Liverpool' },
  { x: 295.5, y: 389.0, primary: 'Mansfield' },
  { x: 296.7, y: 398.2, primary: 'Nottingham' },
  { x: 367.7, y: 413.7, primary: 'Norwich', flip: 'left' },
  { x: 275.5, y: 420.7, primary: 'Birmingham' },
  { x: 337.7, y: 424.8, primary: 'Ely', flip: 'left' },
  { x: 333.7, y: 434.1, primary: 'Cambridge', flip: 'left' },
  { x: 326.5, y: 467.6, primary: 'London', flip: 'left' },
  { x: 269.4, y: 578.4, primary: 'Jersey', svgDot: true },
];

/* viewBox display crops vertical empty space (Shetland Islands aren't in
   the 110m dataset, so y < 100 was blank). Width unchanged at 400. */
const VB_X = 0;
const VB_Y = 100;
const VB_W = 400;
const VB_H = 500;
---

<figure class="ukmap" aria-label="Map of locations across the UK, Ireland, and Jersey where JBE Interiors has delivered work">
  <svg
    class="ukmap__svg"
    viewBox={`${VB_X} ${VB_Y} ${VB_W} ${VB_H}`}
    role="img"
    aria-hidden="true"
    preserveAspectRatio="xMidYMid meet"
  >
    <path class="ukmap__land" d={UK_PATH} />
    <path class="ukmap__land" d={IRELAND_PATH} />

    {/* Jersey — island ellipse + the pin dot drawn directly inside the
        SVG so they share the same coordinate system (the HTML-overlay
        pin wasn't landing inside the ellipse cleanly). The HTML pin
        button below still handles hover + tooltip; its dot is hidden
        via the .ukmap__pin--svg-marker modifier on the <li>. */}
    <ellipse class="ukmap__jersey" cx="269.4" cy="578.4" rx="14" ry="9" />
    <circle class="ukmap__jersey-dot" cx="269.4" cy="578.4" r="3.5" />
    <text x="288" y="583" class="ukmap__jersey-label">JERSEY</text>

    {/* Country labels in stone-coloured uppercase for orientation */}
    <text x="220" y="200" class="ukmap__country-label">UK</text>
    <text x="80" y="380" class="ukmap__country-label">IRELAND</text>
  </svg>

  <ul class="ukmap__pins" role="list">
    {pins.map((pin) => {
      /* Pin position as percentage of the *cropped* viewBox so it lines up
         with the SVG render. x is full width (0–400 → 0–100%). y is
         offset by VB_Y and scaled to VB_H. */
      const xPct = (pin.x / VB_W) * 100;
      const yPct = ((pin.y - VB_Y) / VB_H) * 100;
      const flipClass = pin.flip === 'left' ? ' ukmap__pin--flip-left' : '';
      const svgDotClass = pin.svgDot ? ' ukmap__pin--svg-dot' : '';
      return (
        <li
          class={`ukmap__pin${flipClass}${svgDotClass}`}
          style={`--pin-x: ${xPct}%; --pin-y: ${yPct}%;`}
        >
          <button class="ukmap__pin-button" type="button" aria-label={pin.primary}>
            <span class="ukmap__pin-dot" aria-hidden="true"></span>
            <span class="ukmap__pin-pulse" aria-hidden="true"></span>
            <span class="ukmap__tooltip" role="tooltip">
              <span class="ukmap__tooltip-loc">{pin.primary}</span>
            </span>
          </button>
        </li>
      );
    })}
  </ul>

  <figcaption class="ukmap__caption">
    Selected work across the UK, Ireland, and Jersey
  </figcaption>
</figure>

<script>
  /* For pins whose dot is drawn inside the SVG (Jersey), measure the
     SVG dot's actual rendered position and snap the invisible HTML
     hover button onto it. Solves the small SVG/HTML coordinate
     mismatch that was leaving the tooltip below the visible pin. */
  const alignSvgDotPins = () => {
    document.querySelectorAll<HTMLElement>('.ukmap__pin--svg-dot').forEach((pin) => {
      const map = pin.closest<HTMLElement>('.ukmap');
      if (!map) return;
      const svgDot = map.querySelector<SVGElement>('.ukmap__jersey-dot');
      if (!svgDot) return;

      const dotBox = svgDot.getBoundingClientRect();
      const mapBox = map.getBoundingClientRect();
      if (mapBox.width === 0 || mapBox.height === 0) return;

      const xPct = ((dotBox.left + dotBox.width / 2) - mapBox.left) / mapBox.width * 100;
      const yPct = ((dotBox.top + dotBox.height / 2) - mapBox.top) / mapBox.height * 100;

      pin.style.setProperty('--pin-x', `${xPct}%`);
      pin.style.setProperty('--pin-y', `${yPct}%`);
    });
  };

  if (document.readyState === 'complete') {
    alignSvgDotPins();
  } else {
    window.addEventListener('load', alignSvgDotPins);
  }
  window.addEventListener('resize', alignSvgDotPins);
</script>

<style define:vars={{
  vbW: `${VB_W}`,
  vbH: `${VB_H}`,
}}>
  /* Map sits on the section's paper background — no dark frame,
     no padding. Pins overlay the SVG 1:1 so hover hits correctly. */
  .ukmap {
    margin: 0;
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: var(--vbW) / var(--vbH);
  }

  .ukmap__svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Country shapes use a warm soft stone with a thin terracotta-tinted
     stroke — alive, not flat grey. */
  .ukmap__land {
    fill: var(--stone);
    stroke: color-mix(in srgb, var(--accent) 50%, var(--slate));
    stroke-width: 0.6;
    stroke-linejoin: round;
  }

  .ukmap__jersey {
    fill: var(--stone);
    stroke: color-mix(in srgb, var(--accent) 50%, var(--slate));
    stroke-width: 0.6;
  }

  /* SVG-rendered Jersey dot: terracotta marker, drawn inside the SVG so
     its coordinates share the country shapes' space exactly. */
  .ukmap__jersey-dot {
    fill: var(--accent);
  }

  /* For pins whose dot is drawn in the SVG (currently just Jersey),
     hide the HTML overlay's dot and pulse. The button remains clickable
     so the tooltip still works. */
  .ukmap__pin--svg-dot .ukmap__pin-dot,
  .ukmap__pin--svg-dot .ukmap__pin-pulse {
    display: none;
  }

  .ukmap__jersey-label,
  .ukmap__country-label {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    fill: var(--slate);
  }

  .ukmap__country-label {
    font-size: 11px;
    fill: color-mix(in srgb, var(--slate) 75%, transparent);
  }

  .ukmap__pins {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
  }

  .ukmap__pin {
    position: absolute;
    left: var(--pin-x);
    top: var(--pin-y);
    transform: translate(-50%, -50%);
  }

  .ukmap__pin-button {
    appearance: none;
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    position: relative;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ukmap__pin-dot {
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    position: relative;
    z-index: 2;
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--paper) 90%, transparent);
  }

  /* Pulse ring — terracotta to match the dot. */
  .ukmap__pin-pulse {
    position: absolute;
    inset: 50%;
    width: 10px;
    height: 10px;
    margin: -5px 0 0 -5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.45;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ukmap__pin-pulse {
      animation: ukmap-pulse 3s ease-out infinite;
    }
    .ukmap__pin:nth-child(2)  .ukmap__pin-pulse { animation-delay: 0.15s; }
    .ukmap__pin:nth-child(3)  .ukmap__pin-pulse { animation-delay: 0.30s; }
    .ukmap__pin:nth-child(4)  .ukmap__pin-pulse { animation-delay: 0.45s; }
    .ukmap__pin:nth-child(5)  .ukmap__pin-pulse { animation-delay: 0.60s; }
    .ukmap__pin:nth-child(6)  .ukmap__pin-pulse { animation-delay: 0.75s; }
    .ukmap__pin:nth-child(7)  .ukmap__pin-pulse { animation-delay: 0.90s; }
    .ukmap__pin:nth-child(8)  .ukmap__pin-pulse { animation-delay: 1.05s; }
    .ukmap__pin:nth-child(9)  .ukmap__pin-pulse { animation-delay: 1.20s; }
    .ukmap__pin:nth-child(10) .ukmap__pin-pulse { animation-delay: 1.35s; }
    .ukmap__pin:nth-child(11) .ukmap__pin-pulse { animation-delay: 1.50s; }
    .ukmap__pin:nth-child(12) .ukmap__pin-pulse { animation-delay: 1.65s; }
    .ukmap__pin:nth-child(13) .ukmap__pin-pulse { animation-delay: 1.80s; }
    .ukmap__pin:nth-child(14) .ukmap__pin-pulse { animation-delay: 1.95s; }
    .ukmap__pin:nth-child(15) .ukmap__pin-pulse { animation-delay: 2.10s; }
    .ukmap__pin:nth-child(16) .ukmap__pin-pulse { animation-delay: 2.25s; }
    .ukmap__pin:nth-child(17) .ukmap__pin-pulse { animation-delay: 2.40s; }
    .ukmap__pin:nth-child(18) .ukmap__pin-pulse { animation-delay: 2.55s; }
    .ukmap__pin:nth-child(19) .ukmap__pin-pulse { animation-delay: 2.70s; }
    .ukmap__pin:nth-child(20) .ukmap__pin-pulse { animation-delay: 2.85s; }

    .ukmap__pin-dot,
    .ukmap__tooltip {
      transition:
        transform var(--motion-medium) var(--ease-out),
        opacity var(--motion-medium) var(--ease-out),
        background-color var(--motion-fast) ease;
    }
  }

  @keyframes ukmap-pulse {
    0% { transform: scale(1); opacity: 0.55; }
    80%, 100% { transform: scale(5); opacity: 0; }
  }

  .ukmap__pin-button:hover .ukmap__pin-dot,
  .ukmap__pin-button:focus .ukmap__pin-dot {
    transform: scale(1.6);
    background: var(--ink);
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--accent) 80%, transparent);
  }

  /* Bring the hovered pin to the front so its tooltip isn't clipped by
     adjacent pins. */
  .ukmap__pin:hover,
  .ukmap__pin:focus-within {
    z-index: 5;
  }

  .ukmap__tooltip {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: var(--ink);
    color: var(--paper);
    padding: 6px 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    pointer-events: none;
    z-index: 4;
    text-align: left;
    white-space: nowrap;
    border-left: 2px solid var(--brand-cream);
    box-shadow: 0 12px 24px -8px rgba(17, 17, 17, 0.25);
  }

  .ukmap__tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--ink);
  }

  .ukmap__pin-button:hover .ukmap__tooltip,
  .ukmap__pin-button:focus .ukmap__tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .ukmap__tooltip-loc {
    font-size: var(--t-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--brand-cream);
  }

  .ukmap__tooltip-name {
    font-size: var(--t-body-s);
    color: var(--paper);
  }

  /* Pins flagged flip="left" align their tooltip to the right edge of the
     pin (tooltip extends leftward) so it doesn't clip the map's right side. */
  .ukmap__pin--flip-left .ukmap__tooltip {
    left: auto;
    right: 0;
    transform: translateX(0) translateY(4px);
  }
  .ukmap__pin--flip-left .ukmap__tooltip::after {
    left: auto;
    right: 8px;
    transform: translateX(0);
  }
  .ukmap__pin--flip-left .ukmap__pin-button:hover .ukmap__tooltip,
  .ukmap__pin--flip-left .ukmap__pin-button:focus .ukmap__tooltip {
    transform: translateX(0) translateY(0);
  }

  .ukmap__caption {
    margin-top: var(--space-s);
    font-size: var(--t-caption);
    color: var(--slate);
    line-height: var(--lh-caption);
  }
</style>
