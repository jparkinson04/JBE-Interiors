---
/* Country outlines from Natural Earth 110m (public domain), projected to a
   400x600 viewBox with cosine-corrected equirectangular projection at
   mean latitude 55°N. The viewBox is displayed cropped (y=100 to y=600)
   so the top of the dataset's empty space (where Shetland would sit) is
   trimmed and the section sits tighter on the page. Jersey isn't in the
   110m dataset so it's added manually at its known coordinates. */
const UK_PATH =
  'M150.9,354.4L129.0,344.5L111.1,345.1L117.1,319.4L111.1,293.7L135.4,291.7L166.4,321.4L150.9,354.4ZM243.2,125.5L212.3,177.5L241.8,170.9L273.5,171.1L265.9,210.2L239.9,253.3L269.8,256.3L272.1,261.4L297.9,318.0L317.7,325.7L335.5,380.4L343.7,399.4L378.8,408.5L375.3,439.2L360.5,453.3L372.1,478.1L346.1,503.2L307.4,502.8L258.1,516.0L244.6,506.5L225.5,529.0L198.8,523.6L178.5,541.9L163.1,532.3L205.5,481.9L231.4,471.6L231.2,471.5L186.0,463.5L177.8,444.4L208.0,429.5L192.2,403.7L197.7,372.2L240.7,376.6L240.7,376.6L245.0,348.7L225.6,319.2L225.2,318.5L190.0,310.0L183.2,297.0L193.7,275.6L184.2,262.4L168.6,285.1L166.9,238.8L152.3,214.3L162.8,164.7L185.2,125.8L208.3,129.6L243.2,125.5Z';
const IRELAND_PATH =
  'M111.1,293.7L117.1,319.4L111.1,345.1L129.0,344.5L150.9,354.4L155.7,388.6L133.8,431.5L82.5,459.9L41.6,452.6L65.0,402.5L49.9,353.7L89.3,316.1L111.1,293.7Z';

interface Pin {
  /* Pre-projected viewBox coords (0–400 horizontal, 0–600 vertical) */
  x: number;
  y: number;
  /* Tooltip lines */
  primary: string;
  secondary: string[];
  /* Whether to flip the tooltip to the left so it doesn't clip the edge */
  flip?: 'left' | 'right';
}

/* Pins are sorted top-to-bottom (north-to-south) so their DOM order matches
   their visual order, which makes the stagger animation read naturally.
   Cities with multiple JBE projects (London, Glasgow) group them in one
   tooltip — at this map scale Clydebank vs central Glasgow and St Pauls
   vs Covent Garden read as the same point. */
const pins: Pin[] = [
  {
    x: 244.3,
    y: 229.9,
    primary: 'Dundee',
    secondary: ["Nando's, Dundee"],
  },
  {
    x: 205.0,
    y: 258.0,
    primary: 'Glasgow',
    secondary: ["Nando's, Waterloo Street", "Nando's, Clydebank"],
  },
  {
    x: 288.2,
    y: 357.6,
    primary: 'Leeds',
    secondary: ["Nando's, Thorpe Park"],
  },
  {
    x: 320.6,
    y: 359.0,
    primary: 'Hull',
    secondary: ["Nando's, Hull"],
    flip: 'left',
  },
  {
    x: 252.0,
    y: 359.6,
    primary: 'Preston',
    secondary: ['Wagamama, Preston'],
  },
  {
    x: 287.6,
    y: 377.8,
    primary: 'Sheffield',
    secondary: ['Wagamama, Sheffield'],
  },
  {
    x: 247.7,
    y: 379.7,
    primary: 'Speke, Liverpool',
    secondary: ["Nando's, Speke Liverpool"],
  },
  {
    x: 295.4,
    y: 389.3,
    primary: 'East Midlands',
    secondary: ['Wagamama, East Midlands'],
  },
  {
    x: 337.7,
    y: 424.8,
    primary: 'Ely',
    secondary: ["Nando's, Ely"],
    flip: 'left',
  },
  {
    x: 333.6,
    y: 433.9,
    primary: 'Cambridge',
    secondary: ['Wagamama, Cambridge'],
    flip: 'left',
  },
  {
    x: 327.3,
    y: 467.3,
    primary: 'London',
    secondary: ['Sunday in Brooklyn, James Street', 'Black Tap, Piccadilly'],
    flip: 'left',
  },
];

/* viewBox display crops vertical empty space (Shetland Islands aren't in
   the 110m dataset, so y < 100 was blank). Width unchanged at 400. */
const VB_X = 0;
const VB_Y = 100;
const VB_W = 400;
const VB_H = 500;
---

<figure class="ukmap" aria-label="Map of completed JBE Interiors projects across the British Isles">
  <svg
    class="ukmap__svg"
    viewBox={`${VB_X} ${VB_Y} ${VB_W} ${VB_H}`}
    role="img"
    aria-hidden="true"
    preserveAspectRatio="xMidYMid meet"
  >
    <path class="ukmap__land" d={UK_PATH} />
    <path class="ukmap__land" d={IRELAND_PATH} />

    {/* Jersey — not in the Natural Earth 110m dataset, added manually */}
    <g class="ukmap__jersey">
      <circle cx="269.4" cy="578.4" r="3.5" />
      <text x="278" y="582" class="ukmap__jersey-label">JERSEY</text>
    </g>

    {/* Country labels in stone-coloured uppercase for orientation */}
    <text x="220" y="200" class="ukmap__country-label">UK</text>
    <text x="80" y="380" class="ukmap__country-label">IRELAND</text>
  </svg>

  <ul class="ukmap__pins" role="list">
    {pins.map((pin) => {
      /* Pin position as percentage of the *cropped* viewBox so it lines up
         with the SVG render. x is full width (0–400 → 0–100%). y is
         offset by VB_Y and scaled to VB_H. */
      const xPct = (pin.x / VB_W) * 100;
      const yPct = ((pin.y - VB_Y) / VB_H) * 100;
      const flipClass = pin.flip === 'left' ? ' ukmap__pin--flip-left' : '';
      return (
        <li
          class={`ukmap__pin${flipClass}`}
          style={`--pin-x: ${xPct}%; --pin-y: ${yPct}%;`}
        >
          <button class="ukmap__pin-button" type="button" aria-label={`${pin.primary} — ${pin.secondary.join(', ')}`}>
            <span class="ukmap__pin-dot" aria-hidden="true"></span>
            <span class="ukmap__pin-pulse" aria-hidden="true"></span>
            <span class="ukmap__tooltip" role="tooltip">
              <span class="ukmap__tooltip-loc">{pin.primary}</span>
              {pin.secondary.map((s) => (
                <span class="ukmap__tooltip-name">{s}</span>
              ))}
            </span>
          </button>
        </li>
      );
    })}
  </ul>

  <figcaption class="ukmap__caption">
    Selected work across the UK, Ireland, and Jersey
  </figcaption>
</figure>

<style define:vars={{
  vbW: `${VB_W}`,
  vbH: `${VB_H}`,
}}>
  /* Dark-framed map. Sits in its own ink panel so the country shapes
     and terracotta pins read as a dramatic editorial cartograph rather
     than a flat infographic. */
  .ukmap {
    margin: 0;
    position: relative;
    width: 100%;
    max-width: 520px;
    aspect-ratio: var(--vbW) / var(--vbH);
    background: var(--ink);
    padding: var(--space-m);
    box-shadow: 0 30px 60px -30px rgba(17, 17, 17, 0.45);
  }

  /* Subtle diagonal hairline overlay across the dark panel — picks up
     the editorial texture without being noisy. */
  .ukmap::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(
        135deg,
        transparent 0,
        transparent 49%,
        color-mix(in srgb, var(--paper) 4%, transparent) 49%,
        color-mix(in srgb, var(--paper) 4%, transparent) 51%,
        transparent 51%,
        transparent 100%
      );
    background-size: 8px 8px;
    pointer-events: none;
    opacity: 0.5;
  }

  .ukmap__svg {
    width: 100%;
    height: 100%;
    display: block;
    position: relative;
    z-index: 1;
  }

  .ukmap__land {
    fill: color-mix(in srgb, var(--paper) 12%, var(--ink));
    stroke: color-mix(in srgb, var(--paper) 28%, transparent);
    stroke-width: 0.6;
    stroke-linejoin: round;
  }

  .ukmap__jersey circle {
    fill: color-mix(in srgb, var(--paper) 12%, var(--ink));
    stroke: color-mix(in srgb, var(--paper) 28%, transparent);
    stroke-width: 0.6;
  }

  .ukmap__jersey-label,
  .ukmap__country-label {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    fill: color-mix(in srgb, var(--paper) 55%, transparent);
  }

  .ukmap__country-label {
    font-size: 11px;
    fill: color-mix(in srgb, var(--paper) 45%, transparent);
  }

  .ukmap__pins {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
  }

  .ukmap__pin {
    position: absolute;
    left: var(--pin-x);
    top: var(--pin-y);
    transform: translate(-50%, -50%);
  }

  .ukmap__pin-button {
    appearance: none;
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    position: relative;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ukmap__pin-dot {
    width: 9px;
    height: 9px;
    background: var(--accent);
    border-radius: 50%;
    position: relative;
    z-index: 2;
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--accent) 45%, transparent),
      0 0 16px 2px color-mix(in srgb, var(--accent) 35%, transparent);
  }

  /* Pulse ring — terracotta to match the dot, sized down so the
     animation grows out of the pin. */
  .ukmap__pin-pulse {
    position: absolute;
    inset: 50%;
    width: 9px;
    height: 9px;
    margin: -4.5px 0 0 -4.5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.55;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ukmap__pin-pulse {
      animation: ukmap-pulse 3s ease-out infinite;
    }
    .ukmap__pin:nth-child(2)  .ukmap__pin-pulse { animation-delay: 0.3s; }
    .ukmap__pin:nth-child(3)  .ukmap__pin-pulse { animation-delay: 0.6s; }
    .ukmap__pin:nth-child(4)  .ukmap__pin-pulse { animation-delay: 0.9s; }
    .ukmap__pin:nth-child(5)  .ukmap__pin-pulse { animation-delay: 1.2s; }
    .ukmap__pin:nth-child(6)  .ukmap__pin-pulse { animation-delay: 1.5s; }
    .ukmap__pin:nth-child(7)  .ukmap__pin-pulse { animation-delay: 1.8s; }
    .ukmap__pin:nth-child(8)  .ukmap__pin-pulse { animation-delay: 2.1s; }
    .ukmap__pin:nth-child(9)  .ukmap__pin-pulse { animation-delay: 2.4s; }
    .ukmap__pin:nth-child(10) .ukmap__pin-pulse { animation-delay: 2.7s; }
    .ukmap__pin:nth-child(11) .ukmap__pin-pulse { animation-delay: 3.0s; }

    .ukmap__pin-dot,
    .ukmap__tooltip {
      transition:
        transform var(--motion-medium) var(--ease-out),
        opacity var(--motion-medium) var(--ease-out),
        background-color var(--motion-fast) ease;
    }
  }

  @keyframes ukmap-pulse {
    0% { transform: scale(1); opacity: 0.55; }
    80%, 100% { transform: scale(5); opacity: 0; }
  }

  .ukmap__pin-button:hover .ukmap__pin-dot,
  .ukmap__pin-button:focus-visible .ukmap__pin-dot {
    transform: scale(1.55);
    background: var(--paper);
    box-shadow:
      0 0 0 3px color-mix(in srgb, var(--accent) 70%, transparent),
      0 0 24px 4px color-mix(in srgb, var(--accent) 60%, transparent);
  }

  /* Bring the hovered pin to the front so its tooltip isn't clipped by
     adjacent pins. */
  .ukmap__pin:hover,
  .ukmap__pin:focus-within {
    z-index: 5;
  }

  .ukmap__tooltip {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: var(--paper);
    color: var(--ink);
    padding: 10px 14px;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    pointer-events: none;
    z-index: 4;
    text-align: left;
    white-space: nowrap;
    border-left: 2px solid var(--accent);
    box-shadow: 0 12px 24px -8px rgba(17, 17, 17, 0.4);
  }

  .ukmap__tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--paper);
  }

  .ukmap__pin-button:hover .ukmap__tooltip,
  .ukmap__pin-button:focus-visible .ukmap__tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .ukmap__tooltip-loc {
    font-size: var(--t-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
  }

  .ukmap__tooltip-name {
    font-size: var(--t-body-s);
    color: var(--ink);
  }

  /* Pins flagged flip="left" align their tooltip to the right edge of the
     pin (tooltip extends leftward) so it doesn't clip the map's right side. */
  .ukmap__pin--flip-left .ukmap__tooltip {
    left: auto;
    right: 0;
    transform: translateX(0) translateY(4px);
  }
  .ukmap__pin--flip-left .ukmap__tooltip::after {
    left: auto;
    right: 8px;
    transform: translateX(0);
  }
  .ukmap__pin--flip-left .ukmap__pin-button:hover .ukmap__tooltip,
  .ukmap__pin--flip-left .ukmap__pin-button:focus-visible .ukmap__tooltip {
    transform: translateX(0) translateY(0);
  }

  .ukmap__caption {
    margin-top: var(--space-s);
    font-size: var(--t-caption);
    color: var(--slate);
    line-height: var(--lh-caption);
  }
</style>
