---
/* Country outlines from Natural Earth 110m (public domain), projected to a
   400x600 viewBox with an equirectangular projection cosine-corrected for
   mean latitude 55°N. Jersey isn't in the 110m dataset so it's added as a
   manual marker at its known coordinates. */
const UK_PATH =
  'M150.9,354.4L129.0,344.5L111.1,345.1L117.1,319.4L111.1,293.7L135.4,291.7L166.4,321.4L150.9,354.4ZM243.2,125.5L212.3,177.5L241.8,170.9L273.5,171.1L265.9,210.2L239.9,253.3L269.8,256.3L272.1,261.4L297.9,318.0L317.7,325.7L335.5,380.4L343.7,399.4L378.8,408.5L375.3,439.2L360.5,453.3L372.1,478.1L346.1,503.2L307.4,502.8L258.1,516.0L244.6,506.5L225.5,529.0L198.8,523.6L178.5,541.9L163.1,532.3L205.5,481.9L231.4,471.6L231.2,471.5L186.0,463.5L177.8,444.4L208.0,429.5L192.2,403.7L197.7,372.2L240.7,376.6L240.7,376.6L245.0,348.7L225.6,319.2L225.2,318.5L190.0,310.0L183.2,297.0L193.7,275.6L184.2,262.4L168.6,285.1L166.9,238.8L152.3,214.3L162.8,164.7L185.2,125.8L208.3,129.6L243.2,125.5Z';
const IRELAND_PATH =
  'M111.1,293.7L117.1,319.4L111.1,345.1L129.0,344.5L150.9,354.4L155.7,388.6L133.8,431.5L82.5,459.9L41.6,452.6L65.0,402.5L49.9,353.7L89.3,316.1L111.1,293.7Z';

interface Pin {
  /* x and y are viewBox coordinates (0–400 horizontal, 0–600 vertical) */
  x: number;
  y: number;
  /* Lines shown in the hover tooltip */
  primary: string;
  secondary: string[];
}

/* Pins are pre-projected (see scripts/extract-map.py output). Projects in the
   same city are grouped into one pin so the map stays legible. */
const pins: Pin[] = [
  {
    x: 202.9,
    y: 256.8,
    primary: 'Clydebank',
    secondary: ["Nando's, Clydebank"],
  },
  {
    x: 247.7,
    y: 379.7,
    primary: 'Speke, Liverpool',
    secondary: ["Nando's, Speke Liverpool"],
  },
  {
    x: 295.4,
    y: 389.3,
    primary: 'East Midlands',
    secondary: ['Wagamama, East Midlands'],
  },
  {
    x: 327.3,
    y: 467.5,
    primary: 'London',
    secondary: ['Zelman Meats, St Pauls', 'Parsons'],
  },
];

const VB_W = 400;
const VB_H = 600;
---

<figure class="ukmap" aria-label="Map of completed JBE Interiors projects across the British Isles">
  <svg
    class="ukmap__svg"
    viewBox={`0 0 ${VB_W} ${VB_H}`}
    role="img"
    aria-hidden="true"
    preserveAspectRatio="xMidYMid meet"
  >
    <path class="ukmap__land" d={UK_PATH} />
    <path class="ukmap__land" d={IRELAND_PATH} />

    {/* Jersey — not in the Natural Earth 110m dataset, added manually */}
    <g class="ukmap__jersey">
      <circle cx="269.4" cy="578.4" r="3.5" />
      <text x="278" y="582" class="ukmap__jersey-label">JERSEY</text>
    </g>

    {/* Country labels in stone-coloured uppercase for orientation */}
    <text x="220" y="200" class="ukmap__country-label">UK</text>
    <text x="80" y="380" class="ukmap__country-label">IRELAND</text>
  </svg>

  <ul class="ukmap__pins" role="list">
    {pins.map((pin) => {
      const xPct = (pin.x / VB_W) * 100;
      const yPct = (pin.y / VB_H) * 100;
      return (
        <li
          class="ukmap__pin"
          style={`--pin-x: ${xPct}%; --pin-y: ${yPct}%;`}
        >
          <button class="ukmap__pin-button" type="button" aria-label={`${pin.primary} — ${pin.secondary.join(', ')}`}>
            <span class="ukmap__pin-dot" aria-hidden="true"></span>
            <span class="ukmap__pin-pulse" aria-hidden="true"></span>
            <span class="ukmap__tooltip" role="tooltip">
              <span class="ukmap__tooltip-loc">{pin.primary}</span>
              {pin.secondary.map((s) => (
                <span class="ukmap__tooltip-name">{s}</span>
              ))}
            </span>
          </button>
        </li>
      );
    })}
  </ul>

  <figcaption class="ukmap__caption">
    Selected work across the UK, Ireland, and Jersey
  </figcaption>
</figure>

<style>
  .ukmap {
    margin: 0;
    position: relative;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 400 / 600;
  }

  .ukmap__svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .ukmap__land {
    fill: var(--stone);
    stroke: var(--slate);
    stroke-width: 0.6;
    stroke-linejoin: round;
  }

  .ukmap__jersey circle {
    fill: var(--stone);
    stroke: var(--slate);
    stroke-width: 0.6;
  }

  .ukmap__jersey-label,
  .ukmap__country-label {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    fill: var(--slate);
  }

  .ukmap__country-label {
    font-size: 11px;
    fill: color-mix(in srgb, var(--slate) 70%, transparent);
  }

  .ukmap__pins {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    inset: 0;
  }

  .ukmap__pin {
    position: absolute;
    left: var(--pin-x);
    top: var(--pin-y);
    transform: translate(-50%, -50%);
  }

  .ukmap__pin-button {
    appearance: none;
    background: none;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    position: relative;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ukmap__pin-dot {
    width: 9px;
    height: 9px;
    background: var(--ink);
    border-radius: 50%;
    position: relative;
    z-index: 2;
  }

  /* Soft animated pulse ring around each pin */
  .ukmap__pin-pulse {
    position: absolute;
    inset: 50%;
    width: 9px;
    height: 9px;
    margin: -4.5px 0 0 -4.5px;
    border-radius: 50%;
    background: var(--ink);
    opacity: 0.18;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ukmap__pin-pulse {
      animation: ukmap-pulse 2.6s ease-out infinite;
    }
    .ukmap__pin:nth-child(2) .ukmap__pin-pulse { animation-delay: 0.6s; }
    .ukmap__pin:nth-child(3) .ukmap__pin-pulse { animation-delay: 1.2s; }
    .ukmap__pin:nth-child(4) .ukmap__pin-pulse { animation-delay: 1.8s; }

    .ukmap__pin-dot,
    .ukmap__tooltip {
      transition:
        transform var(--motion-medium) var(--ease-out),
        opacity var(--motion-medium) var(--ease-out),
        background-color var(--motion-fast) ease;
    }
  }

  @keyframes ukmap-pulse {
    0% { transform: scale(1); opacity: 0.4; }
    80%, 100% { transform: scale(4.2); opacity: 0; }
  }

  .ukmap__pin-button:hover .ukmap__pin-dot,
  .ukmap__pin-button:focus-visible .ukmap__pin-dot {
    transform: scale(1.4);
    background: var(--accent);
  }

  .ukmap__tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: var(--ink);
    color: var(--paper);
    padding: 10px 14px;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    pointer-events: none;
    z-index: 4;
    text-align: left;
    white-space: nowrap;
  }

  .ukmap__tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--ink);
  }

  .ukmap__pin-button:hover .ukmap__tooltip,
  .ukmap__pin-button:focus-visible .ukmap__tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .ukmap__tooltip-loc {
    font-size: var(--t-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: color-mix(in srgb, var(--paper) 60%, transparent);
  }

  .ukmap__tooltip-name {
    font-size: var(--t-body-s);
    color: var(--paper);
  }

  .ukmap__caption {
    margin-top: var(--space-s);
    font-size: var(--t-caption);
    color: var(--slate);
    line-height: var(--lh-caption);
  }

  /* Edge cases: pins near the right edge would push tooltip off-screen.
     Flip the tooltip to the left for the London pin. */
  .ukmap__pin:last-child .ukmap__tooltip {
    left: auto;
    right: 0;
    transform: translateX(0) translateY(4px);
  }
  .ukmap__pin:last-child .ukmap__tooltip::after {
    left: auto;
    right: 8px;
    transform: translateX(0);
  }
  .ukmap__pin:last-child .ukmap__pin-button:hover .ukmap__tooltip,
  .ukmap__pin:last-child .ukmap__pin-button:focus-visible .ukmap__tooltip {
    transform: translateX(0) translateY(0);
  }
</style>
