---
const slides = [
  {
    src: '/images/hero/wagamamas-east-midlands.jpg',
    alt: "Wagamama's East Midlands. Banquette seating with curated artwork against chevron-clad walls and pendant lighting.",
  },
  {
    src: '/images/hero/nandos-liverpool.jpg',
    alt: "Nando's Liverpool. Long restaurant interior with a geometric ceiling structure, orange seating, and timber floors.",
  },
  {
    src: '/images/hero/nandos-clydebank.jpg',
    alt: "Nando's Clydebank. Booth seating beneath a slatted yellow ceiling with bottle-lined walls.",
  },
  {
    src: '/images/hero/parsons.jpg',
    alt: "Parsons. Washroom interior with terracotta tiling, twin circular mirrors, and a graphic painted wall pattern.",
  },
];

const cycleSeconds = 8;
const totalSeconds = slides.length * cycleSeconds;
---

<section class="hero" aria-label="JBE Interiors — selected work">
  <div class="hero__slides" aria-hidden="false">
    {slides.map((slide, i) => (
      <div
        class="hero__slide"
        style={`--slide-delay: ${-(totalSeconds - i * cycleSeconds)}s;`}
      >
        <img
          class="hero__slide-img"
          src={slide.src}
          alt={slide.alt}
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          decoding="async"
        />
      </div>
    ))}
  </div>

  <div class="hero__dim" aria-hidden="true"></div>

  <div class="hero__content">
    <img
      class="hero__wordmark"
      src="/assets/jbe-logo-light.png"
      alt="JBE Interiors"
      width="216"
      height="140"
    />
  </div>
</section>

<style define:vars={{ totalSeconds: `${totalSeconds}s` }}>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    background: var(--ink);
    overflow: hidden;
    margin-top: calc(-1 * var(--header-height));
  }

  .hero__slides {
    position: absolute;
    inset: 0;
  }

  /* The outer slide is the opacity layer; the inner img holds the slow
     ken-burns zoom so opacity and scale can ease independently. */
  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    will-change: opacity;
  }

  .hero__slide:first-child {
    opacity: 1;
  }

  .hero__slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.0);
    will-change: transform;
  }

  .hero__dim {
    position: absolute;
    inset: 0;
    background: rgba(17, 17, 17, 0.28);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--header-height) var(--grid-margin) 0;
  }

  .hero__wordmark {
    width: auto;
    height: 112px;
    max-width: min(420px, 70vw);
    object-fit: contain;
    filter: drop-shadow(0 2px 24px rgba(0, 0, 0, 0.35));
  }

  @media (max-width: 1024px) {
    .hero__wordmark {
      height: 96px;
    }
  }

  @media (max-width: 640px) {
    .hero__wordmark {
      height: 72px;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__slide {
      /* Long 2s crossfade with a soft sinusoidal easing. */
      animation: heroSlideOpacity var(--totalSeconds) cubic-bezier(0.45, 0, 0.55, 1) infinite;
      animation-delay: var(--slide-delay);
    }
    .hero__slide-img {
      /* Slow continuous ken-burns drift, linear so motion never stalls. */
      animation: heroSlideZoom var(--totalSeconds) linear infinite;
      animation-delay: var(--slide-delay);
    }
  }

  @keyframes heroSlideOpacity {
    0%, 18.75% { opacity: 1; }
    25%, 93.75% { opacity: 0; }
    100% { opacity: 1; }
  }

  @keyframes heroSlideZoom {
    0% { transform: scale(1.0); }
    18.75% { transform: scale(1.05); }
    25% { transform: scale(1.07); }
    93.75% { transform: scale(1.0); }
    100% { transform: scale(1.0); }
  }
</style>
