---
/* Slide order starts outside the Sunday in Brooklyn shopfront, then
   steps through the door — the tour goes from street to interior. */
const slides = [
  {
    src: '/images/projects/sunday-in-brooklyn/gallery-1.jpg',
    alt: 'Sunday in Brooklyn, James Street. Shopfront with striped awning, signage, and pavement dining.',
  },
  {
    src: '/images/projects/sunday-in-brooklyn/hero.jpg',
    alt: 'Sunday in Brooklyn, James Street. Warmly lit dining room with hanging plants and tan banquette seating.',
  },
  {
    src: '/images/projects/nandos-waterloo-glasgow/hero.jpg',
    alt: "Nando's Waterloo Street, Glasgow. Wide dining room beneath suspended copper-ring ceiling installations.",
  },
  {
    src: '/images/projects/black-tap-piccadilly/hero.jpg',
    alt: 'Black Tap, Piccadilly. Bar interior with monochrome striped flooring, dramatic pendant lighting and brass bar fittings.',
  },
];

const cycleSeconds = 8;
const totalSeconds = slides.length * cycleSeconds;
---

<section class="hero" aria-label="JBE Interiors — selected work">
  <div class="hero__slides" aria-hidden="false">
    {slides.map((slide, i) => (
      <div
        class="hero__slide"
        style={`--slide-delay: ${-(totalSeconds - i * cycleSeconds)}s;`}
      >
        <img
          class="hero__slide-img"
          src={slide.src}
          alt={slide.alt}
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          decoding="async"
        />
      </div>
    ))}
  </div>

  <div class="hero__dim" aria-hidden="true"></div>

  <div class="hero__content">
    <img
      class="hero__wordmark"
      src="/assets/jbe-mark.png"
      alt="JBE Interiors"
      width="430"
      height="284"
    />
  </div>
</section>

<style define:vars={{ totalSeconds: `${totalSeconds}s` }}>
  .hero {
    position: relative;
    /* svh uses the smallest viewport state (mobile address bar visible)
       so the hero doesn't resize when the browser chrome retracts —
       eliminates the visible reshape on refresh / scroll start. */
    height: 100vh;
    height: 100svh;
    min-height: 600px;
    background: var(--ink);
    overflow: hidden;
    margin-top: calc(-1 * var(--header-height));
  }

  .hero__slides {
    position: absolute;
    inset: 0;
  }

  /* The outer slide is the opacity layer; the inner img holds the slow
     ken-burns zoom so opacity and scale can ease independently. */
  .hero__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    will-change: opacity;
  }

  .hero__slide:first-child {
    opacity: 1;
  }

  .hero__slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.0);
    will-change: transform;
  }

  .hero__dim {
    position: absolute;
    inset: 0;
    /* Flat dim for wordmark legibility, plus a stronger gradient at the
       very top so the transparent header's cream nav links stay legible
       over any photograph. */
    background:
      linear-gradient(
        to bottom,
        rgba(17, 17, 17, 0.55) 0,
        rgba(17, 17, 17, 0) 180px
      ),
      rgba(17, 17, 17, 0.28);
    pointer-events: none;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--header-height) var(--grid-margin) 0;
  }

  /* Transparent cutout mark (white cursive + cream INTERIORS) floats
     directly over the photography — no grey square behind it. */
  .hero__wordmark {
    width: auto;
    height: 160px;
    max-width: min(420px, 70vw);
    object-fit: contain;
    filter: drop-shadow(0 4px 28px rgba(0, 0, 0, 0.45));
  }

  @media (max-width: 1024px) {
    .hero__wordmark {
      height: 132px;
    }
  }

  @media (max-width: 640px) {
    .hero__wordmark {
      height: 100px;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__slide {
      /* Long 2s crossfade with a soft sinusoidal easing. */
      animation: heroSlideOpacity var(--totalSeconds) cubic-bezier(0.45, 0, 0.55, 1) infinite;
      animation-delay: var(--slide-delay);
    }
    .hero__slide-img {
      /* Slow continuous ken-burns drift, linear so motion never stalls. */
      animation: heroSlideZoom var(--totalSeconds) linear infinite;
      animation-delay: var(--slide-delay);
    }
  }

  @keyframes heroSlideOpacity {
    0%, 18.75% { opacity: 1; }
    25%, 93.75% { opacity: 0; }
    100% { opacity: 1; }
  }

  @keyframes heroSlideZoom {
    0% { transform: scale(1.0); }
    18.75% { transform: scale(1.05); }
    25% { transform: scale(1.07); }
    93.75% { transform: scale(1.0); }
    100% { transform: scale(1.0); }
  }
</style>
