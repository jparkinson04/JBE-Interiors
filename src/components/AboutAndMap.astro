---
import UKMap from './UKMap.astro';
---

<section class="about-map" aria-label="About JBE Interiors">
  <div class="about-map__inner">
    <div class="about-map__copy">
      <p class="eyebrow">01 / About</p>
      <h2 class="about-map__heading">Restaurant and retail fit&#8209;outs, from concept to handover.</h2>

      <div class="about-map__body">
        <p>
          JBE Interiors delivers complete fit-out programmes for restaurant
          and retail brands across the UK, Ireland, and Jersey. We work
          directly with national chains, hospitality groups, and independent
          operators.
        </p>
        <p>
          Our scope covers everything from initial site survey through to
          handover: programme management, principal contracting, joinery,
          M&amp;E coordination, finishes, FF&amp;E install, and snagging.
        </p>
        <p>
          We&rsquo;ve delivered sites for Wagamama, Nando&rsquo;s, and
          independent operators including Parsons and Zelmans.
        </p>
      </div>

      <dl class="about-map__stats">
        <div>
          <dt class="eyebrow">Operating since</dt>
          <dd>1998</dd>
        </div>
        <div>
          <dt class="eyebrow">Based</dt>
          <dd>Doncaster</dd>
        </div>
        <div>
          <dt class="eyebrow">Coverage</dt>
          <dd>UK, Ireland, Jersey</dd>
        </div>
      </dl>
    </div>

    <div class="about-map__map">
      <UKMap />
    </div>
  </div>
</section>

<style>
  .about-map {
    background: var(--paper);
    /* Tighter bottom padding so the section doesn't double up with the
       Instagram feed's own top padding directly below. */
    padding-block: var(--space-xl) var(--space-m);
  }

  .about-map__inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: var(--space-2xl);
    /* Stretch both columns to the section's natural height (set by the
       taller map), so the stats anchor to the bottom and we don't leave
       a tall empty strip beneath the copy. */
    align-items: stretch;
  }

  .about-map__copy {
    display: flex;
    flex-direction: column;
    /* Push the stats block to the bottom of the column so it aligns with
       the foot of the map. The gap between description and stats absorbs
       the difference in column heights. */
    justify-content: space-between;
    gap: var(--space-l);
  }

  .about-map__heading {
    font-size: var(--t-display-m);
    font-weight: 300;
    letter-spacing: var(--ls-display);
    line-height: var(--lh-display);
    color: var(--ink);
    margin-top: var(--space-s);
    max-width: 18ch;
  }

  .about-map__body {
    margin-top: var(--space-s);
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .about-map__body p {
    font-size: var(--t-body-m);
    color: var(--ink);
    line-height: var(--lh-body);
    max-width: 56ch;
  }

  .about-map__stats {
    margin: 0;
    padding-top: var(--space-l);
    border-top: 1px solid var(--bone);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-m);
  }

  .about-map__stats > div {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .about-map__stats dd {
    margin: 0;
    font-size: var(--t-body-m);
    color: var(--ink);
  }

  .about-map__map {
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
  }

  @media (max-width: 900px) {
    .about-map__inner {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
      align-items: start;
    }
    .about-map__copy {
      justify-content: flex-start;
    }
    .about-map__map {
      justify-content: center;
    }
    .about-map__stats {
      grid-template-columns: 1fr;
      gap: var(--space-m);
    }
  }
</style>
