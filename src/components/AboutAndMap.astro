---
/* About section — stats tiles above a two-column editorial block:
   copy + CTA on the left, a photograph with an offset brand-grey
   frame on the right. (The UK map that used to sit here was removed
   at Jason's request, July 2026.) */
---

<section class="about-map" aria-label="About JBE Interiors">
  <div class="about-map__inner">
    <dl class="about-map__meta">
      <div class="about-map__meta-tile">
        <dt class="eyebrow">Incorporated</dt>
        <dd>04/08/2017</dd>
      </div>
      <div class="about-map__meta-tile">
        <dt class="eyebrow">Based</dt>
        <dd>Doncaster</dd>
      </div>
      <div class="about-map__meta-tile">
        <dt class="eyebrow">Coverage</dt>
        <dd>UK, Ireland, Jersey</dd>
      </div>
    </dl>

    <div class="about-map__grid">
      <div class="about-map__copy">
        <header class="about-map__header">
          <p class="eyebrow">About</p>
          <h2 class="about-map__heading">
            Restaurant and retail fit&#8209;outs, from concept to handover.
          </h2>
        </header>

        <div class="about-map__body">
          <p>
            JBE Interiors delivers complete fit-out programmes for restaurant
            and retail brands across the UK, Ireland, and Jersey. We work
            directly with national chains, hospitality groups, and independent
            operators.
          </p>
          <p>
            Our scope covers everything from initial site survey through to
            handover: programme management, principal contracting, joinery,
            M&amp;E coordination, finishes, FF&amp;E install, and snagging.
          </p>
          <p>
            We&rsquo;ve delivered sites for Wagamama, Nando&rsquo;s, and
            independent operators including Sunday in Brooklyn, Black Tap,
            Parsons, and Zelmans.
          </p>
        </div>

        <a href="/projects" class="about-map__cta">View our work &rarr;</a>
      </div>

      <figure class="about-map__figure">
        <img
          src="/images/projects/nandos-waterloo-glasgow/hero.jpg"
          alt="Nando's Waterloo Street, Glasgow — dining room beneath suspended copper-ring ceiling installations."
          loading="lazy"
          decoding="async"
          width="1800"
          height="1200"
        />
        <figcaption class="about-map__figure-caption">
          Nando&rsquo;s, Waterloo Street, Glasgow
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .about-map {
    background: var(--paper);
    padding-block: var(--space-l) var(--space-l);
  }

  .about-map__inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  /* Stats as three discrete boxes. Values in large display serif so
     the numbers carry weight at a glance. */
  .about-map__meta {
    margin: 0 0 var(--space-xl);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-m);
  }

  .about-map__meta-tile {
    background: var(--stone);
    padding: var(--space-m);
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-left: 2px solid var(--accent);
  }

  .about-map__meta-tile dt {
    margin: 0;
  }

  .about-map__meta-tile dd {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(24px, 2vw, 32px);
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--ink);
  }

  /* Editorial split: copy column left, photograph right. */
  .about-map__grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: var(--space-xl);
    align-items: center;
  }

  .about-map__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .about-map__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .about-map__heading {
    font-size: var(--t-display-m);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ink);
    max-width: 22ch;
  }

  .about-map__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .about-map__body p {
    font-size: var(--t-body-m);
    color: var(--ink);
    line-height: var(--lh-body);
    max-width: 56ch;
  }

  .about-map__cta {
    align-self: flex-start;
    font-size: var(--t-body-s);
    font-weight: 500;
    letter-spacing: var(--ls-button);
    text-transform: uppercase;
    color: var(--ink);
    border-bottom: 1px solid var(--bone);
    padding-bottom: 2px;
  }

  .about-map__cta:hover,
  .about-map__cta:focus-visible {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* Photograph with an offset brand-grey frame behind it — gives the
     section depth without adding noise. Caption chip sits over the
     bottom-left of the image. */
  .about-map__figure {
    margin: 0;
    position: relative;
  }

  .about-map__figure::before {
    content: '';
    position: absolute;
    inset: var(--space-s) calc(-1 * var(--space-s)) calc(-1 * var(--space-s)) var(--space-s);
    background: var(--brand-grey);
    z-index: 0;
  }

  .about-map__figure img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .about-map__figure-caption {
    position: absolute;
    z-index: 2;
    bottom: var(--space-s);
    left: var(--space-s);
    font-size: var(--t-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--paper);
    background: rgba(17, 17, 17, 0.7);
    padding: 6px 10px;
  }

  @media (max-width: 900px) {
    .about-map__grid {
      grid-template-columns: 1fr;
      gap: var(--space-l);
      align-items: start;
    }
    /* Keep the offset frame inside the viewport on small screens. */
    .about-map__figure {
      margin-right: var(--space-s);
    }
  }

  @media (max-width: 560px) {
    .about-map__meta {
      grid-template-columns: 1fr;
      gap: var(--space-s);
    }
    .about-map__meta-tile {
      padding: var(--space-s) var(--space-m);
    }
  }
</style>
