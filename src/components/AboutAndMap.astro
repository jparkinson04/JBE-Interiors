---
import UKMap from './UKMap.astro';
---

<section class="about-map" aria-label="About JBE Interiors">
  <div class="about-map__inner">
    <dl class="about-map__meta">
      <div>
        <dt class="eyebrow">Operating since</dt>
        <dd>1998</dd>
      </div>
      <div>
        <dt class="eyebrow">Based</dt>
        <dd>Doncaster</dd>
      </div>
      <div>
        <dt class="eyebrow">Coverage</dt>
        <dd>UK, Ireland, Jersey</dd>
      </div>
    </dl>

    <div class="about-map__grid">
      <div class="about-map__copy">
        <span class="section-mark" aria-hidden="true"></span>
        <p class="eyebrow">About</p>
        <h2 class="about-map__heading">
          Restaurant and retail fit&#8209;outs, from concept to handover.
        </h2>

        <div class="about-map__body">
          <p>
            JBE Interiors delivers complete fit-out programmes for restaurant
            and retail brands across the UK, Ireland, and Jersey. We work
            directly with national chains, hospitality groups, and independent
            operators.
          </p>
          <p>
            Our scope covers everything from initial site survey through to
            handover: programme management, principal contracting, joinery,
            M&amp;E coordination, finishes, FF&amp;E install, and snagging.
          </p>
          <p>
            We&rsquo;ve delivered sites for Wagamama, Nando&rsquo;s, and
            independent operators including Parsons and Zelmans.
          </p>
        </div>
      </div>

      <div class="about-map__map">
        <UKMap />
      </div>
    </div>
  </div>
</section>

<style>
  .about-map {
    background: var(--paper);
    /* Section top padding intentionally tight — the meta strip should
       sit close to the hero rather than floating in space. */
    padding-block: var(--space-l) var(--space-m);
  }

  .about-map__inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  /* Masthead-style meta strip at the top of the section. Reads like a
     publication's standfirst credits: tight uppercase eyebrow above a
     larger serif value, separated by thin column dividers. */
  .about-map__meta {
    margin: 0 0 var(--space-l);
    padding: var(--space-s) 0;
    border-top: 1px solid var(--bone);
    border-bottom: 1px solid var(--bone);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .about-map__meta > div {
    padding-inline: var(--space-l);
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-left: 1px solid var(--bone);
  }

  .about-map__meta > div:first-child {
    border-left: 0;
    padding-left: 0;
  }

  .about-map__meta > div:last-child {
    padding-right: 0;
  }

  .about-map__meta dt {
    margin: 0;
  }

  .about-map__meta dd {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(20px, 1.6vw, 26px);
    letter-spacing: -0.01em;
    line-height: 1.05;
    color: var(--ink);
  }

  .about-map__grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: var(--space-xl);
    align-items: center;
  }

  .about-map__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .about-map__heading {
    font-size: var(--t-display-m);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ink);
    margin-top: var(--space-s);
    max-width: 22ch;
  }

  .about-map__body {
    margin-top: var(--space-s);
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .about-map__body p {
    font-size: var(--t-body-m);
    color: var(--ink);
    line-height: var(--lh-body);
    max-width: 56ch;
  }

  .about-map__map {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  @media (max-width: 900px) {
    .about-map__meta {
      grid-template-columns: 1fr;
    }
    .about-map__meta > div {
      padding: var(--space-s) 0;
      border-left: 0;
      border-top: 1px solid var(--bone);
    }
    .about-map__meta > div:first-child {
      border-top: 0;
    }
    .about-map__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
      align-items: start;
    }
    .about-map__map {
      justify-content: center;
    }
  }
</style>
