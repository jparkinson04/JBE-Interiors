---
const { pathname } = Astro.url;
const isHome = pathname === '/';
const isWork = pathname === '/projects' || pathname.startsWith('/projects/');
const isContact = pathname === '/contact' || pathname.startsWith('/contact/');
---

<header class:list={["site-header", { "site-header--overlay": isHome }]}>
  <div class="site-header__inner">
    <a href="/" class="site-header__logo" aria-label="JBE Interiors — home">
      <img
        src="/assets/jbe-mark.png"
        alt="JBE Interiors"
        width="430"
        height="284"
        class="site-header__logo-img"
      />
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <a href="/" class:list={["nav-link", { "is-active": isHome }]}>Home</a>
      <a href="/projects" class:list={["nav-link", { "is-active": isWork }]}>Projects</a>
      <a href="/contact" class:list={["nav-link", { "is-active": isContact }]}>Contact</a>
    </nav>
  </div>
</header>

<style>
  /* Header bar matches the badge's grey exactly, so the square logo
     dissolves into the bar and reads as a single branded strip. */
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    height: var(--header-height);
    background: var(--brand-grey);
    border-bottom: 1px solid rgba(0, 0, 0, 0.12);
  }

  /* On the homepage the bar starts transparent so the hero photography
     runs to the very top of the viewport; a script swaps in .is-scrolled
     (solid grey again) as soon as the visitor scrolls, keeping the nav
     legible over page content. Other pages keep the solid bar. */
  .site-header--overlay:not(.is-scrolled) {
    background: transparent;
    border-bottom-color: transparent;
  }

  @media (prefers-reduced-motion: no-preference) {
    .site-header--overlay {
      transition:
        background-color 300ms ease,
        border-color 300ms ease;
    }
  }

  .site-header__inner {
    height: 100%;
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
  }

  .site-header__logo {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
  }

  /* Interiors logo in top-left — sized to match the footer logo (40px)
     per Jason, so the mark reads consistently at both ends of the page. */
  .site-header__logo-img {
    height: 40px;
    width: auto;
    display: block;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-m);
  }

  .nav-link {
    position: relative;
    font-size: var(--t-body-s);
    font-weight: 500;
    letter-spacing: var(--ls-button);
    text-transform: uppercase;
    color: var(--brand-cream);
    padding-block: 4px;
  }

  .nav-link:hover {
    color: #ffffff;
  }

  /* Grey focus ring (global default) is invisible on the grey bar —
     use cream here so keyboard focus stays visible. */
  .nav-link:focus-visible,
  .site-header__logo:focus-visible {
    outline-color: var(--brand-cream);
  }

  .nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--brand-cream);
  }

  @media (max-width: 640px) {
    .site-header__logo-img {
      height: 36px;
    }
    .site-header__nav {
      gap: var(--space-s);
    }
  }
</style>

<script>
  /* Solidify the overlay header once the page scrolls.

     Hysteresis: turn solid past 72px but only turn transparent again
     under 8px. A single threshold flaps while Lenis interpolates the
     scroll position around it, which read as the bar glitching when
     scrolling back up the hero. rAF-throttled so at most one class
     change per frame. */
  const header = document.querySelector('.site-header--overlay');
  if (header) {
    const SOLID_AT = 72;
    const CLEAR_AT = 8;
    let ticking = false;

    const update = () => {
      ticking = false;
      const y = window.scrollY;
      if (y > SOLID_AT) {
        header.classList.add('is-scrolled');
      } else if (y < CLEAR_AT) {
        header.classList.remove('is-scrolled');
      }
      /* Between the two thresholds: keep the current state. */
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
