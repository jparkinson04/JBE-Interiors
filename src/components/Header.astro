---
const { pathname } = Astro.url;
const isWork = pathname === '/projects' || pathname.startsWith('/projects/');
const isContact = pathname === '/contact' || pathname.startsWith('/contact/');
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__logo" aria-label="JBE Interiors — home">
      <span class="wordmark">JBE Interiors</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <a href="/projects" class:list={["nav-link", { "is-active": isWork }]}>Work</a>
      <a href="/contact" class:list={["nav-link", { "is-active": isContact }]}>Contact</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    height: var(--header-height);
    background: var(--paper);
    border-bottom: 1px solid var(--bone);
  }

  .site-header__inner {
    height: 100%;
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
  }

  .site-header__logo {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
  }

  /* Placeholder wordmark — text fallback until a clean Interiors-only
     vector mark is supplied. Heights match the design system (32 / 28). */
  .wordmark {
    font-size: 22px;
    font-weight: 300;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-m);
  }

  .nav-link {
    position: relative;
    font-size: var(--t-body-s);
    font-weight: 500;
    letter-spacing: var(--ls-button);
    text-transform: uppercase;
    color: var(--ink);
    padding-block: 4px;
  }

  .nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--accent);
  }

  @media (max-width: 640px) {
    .wordmark {
      font-size: 18px;
    }
    .site-header__nav {
      gap: var(--space-s);
    }
  }
</style>
