---
/* The form posts to whatever endpoint is set in the CONTACT_FORM_ENDPOINT
   env var (Formspree, Web3Forms, a Vercel API route — anything that
   accepts a POST). Without it, the form renders but submission won't
   deliver; the visible note explains. */
const endpoint = import.meta.env.CONTACT_FORM_ENDPOINT;
const isConfigured = Boolean(endpoint);
---

<form
  class="contact-form"
  action={endpoint ?? '#'}
  method="POST"
  novalidate
  aria-describedby={!isConfigured ? 'contact-form-status' : undefined}
>
  <div class="contact-form__row contact-form__row--split">
    <div class="contact-form__field">
      <label for="cf-name">Name</label>
      <input
        id="cf-name"
        name="name"
        type="text"
        autocomplete="name"
        required
      />
    </div>
    <div class="contact-form__field">
      <label for="cf-email">Email</label>
      <input
        id="cf-email"
        name="email"
        type="email"
        autocomplete="email"
        required
      />
    </div>
  </div>

  <div class="contact-form__row contact-form__row--split">
    <div class="contact-form__field">
      <label for="cf-company">Company <span class="contact-form__hint">(optional)</span></label>
      <input
        id="cf-company"
        name="company"
        type="text"
        autocomplete="organization"
      />
    </div>
    <div class="contact-form__field">
      <label for="cf-phone">Phone <span class="contact-form__hint">(optional)</span></label>
      <input
        id="cf-phone"
        name="phone"
        type="tel"
        autocomplete="tel"
      />
    </div>
  </div>

  <div class="contact-form__row">
    <div class="contact-form__field">
      <label for="cf-message">Tell us about the project</label>
      <textarea
        id="cf-message"
        name="message"
        rows="6"
        required
        placeholder="Brand, site location, scope, target programme. Anything you can share helps."
      ></textarea>
    </div>
  </div>

  <!-- Subject line for the email Jason receives. -->
  <input type="hidden" name="_subject" value="New enquiry — jbeinteriors.com" />

  <!-- Honeypot — Formspree and similar services drop submissions
       where this hidden field is filled in. -->
  <div class="contact-form__honeypot" aria-hidden="true">
    <label for="cf-website">Website</label>
    <input id="cf-website" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
  </div>

  <div class="contact-form__actions">
    <button type="submit" class="btn btn--primary" disabled={!isConfigured}>
      Send enquiry
    </button>
    {!isConfigured && (
      <p id="contact-form-status" class="contact-form__status" role="status">
        Form is not yet connected to a delivery endpoint. Set
        <code>CONTACT_FORM_ENDPOINT</code> in Vercel to activate.
      </p>
    )}
  </div>
</form>

<style>
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .contact-form__row--split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-l);
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .contact-form__field label {
    font-size: var(--t-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--slate);
  }

  .contact-form__hint {
    text-transform: none;
    letter-spacing: 0;
    color: var(--slate);
    font-weight: 400;
    margin-left: 4px;
  }

  .contact-form__field input,
  .contact-form__field textarea {
    font: inherit;
    font-size: var(--t-body-l);
    font-weight: 400;
    color: var(--ink);
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--bone);
    padding: 12px 0;
    line-height: var(--lh-body);
    width: 100%;
    border-radius: 0;
  }

  .contact-form__field textarea {
    border: 1px solid var(--bone);
    padding: 16px;
    resize: vertical;
    min-height: 160px;
    font-size: var(--t-body-m);
  }

  .contact-form__field input::placeholder,
  .contact-form__field textarea::placeholder {
    color: var(--slate);
    opacity: 0.7;
  }

  @media (prefers-reduced-motion: no-preference) {
    .contact-form__field input,
    .contact-form__field textarea {
      transition: border-color var(--motion-fast) ease;
    }
  }

  .contact-form__field input:focus,
  .contact-form__field textarea:focus {
    outline: none;
    border-color: var(--ink);
  }

  .contact-form__field input:focus-visible,
  .contact-form__field textarea:focus-visible {
    outline: none;
    border-color: var(--accent);
  }

  .contact-form__honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact-form__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-s);
    margin-top: var(--space-m);
  }

  .contact-form__actions .btn[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .contact-form__status {
    font-size: var(--t-caption);
    color: var(--slate);
    max-width: 48ch;
  }

  .contact-form__status code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.92em;
    background: var(--stone);
    padding: 2px 6px;
  }

  @media (max-width: 640px) {
    .contact-form__row--split {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
  }
</style>
