---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <a href="/" class="site-footer__logo" aria-label="JBE Interiors — home">
        <span class="wordmark wordmark--large">JBE Interiors</span>
      </a>

      <address class="site-footer__contact">
        <a href="tel:+441302322202">01302 322202</a>
        <a href="mailto:jason@jbeinteriors.com">jason@jbeinteriors.com</a>
        <span>305 Churchway, Doncaster, DN12TB</span>
      </address>
    </div>

    <div class="site-footer__instagram">
      <a href="https://www.instagram.com/jbeinteriors/" target="_blank" rel="noopener" class="instagram-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" />
          <circle cx="12" cy="12" r="4" />
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
        </svg>
        <span>View on Instagram &rarr;</span>
      </a>
    </div>

    <hr class="site-footer__rule" />

    <div class="site-footer__meta">
      <span>&copy; JBE Interiors Ltd {year}</span>
      <span>Site by Seam</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--paper);
    padding-block: var(--space-xl);
  }

  .site-footer__inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--grid-gutter);
    align-items: start;
  }

  .site-footer__logo {
    color: var(--paper);
  }

  .wordmark--large {
    font-size: 40px;
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .site-footer__contact {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    align-items: flex-end;
    text-align: right;
    font-size: var(--t-body-m);
  }

  .site-footer__contact a:hover {
    color: var(--accent);
  }

  .site-footer__instagram {
    margin-top: var(--space-l);
  }

  .instagram-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-s);
    font-size: var(--t-body-s);
    font-weight: 500;
    letter-spacing: var(--ls-button);
    text-transform: uppercase;
    color: var(--paper);
  }

  .instagram-link:hover {
    color: var(--accent);
  }

  .site-footer__rule {
    margin: var(--space-l) 0 var(--space-m);
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--paper) 20%, transparent);
  }

  .site-footer__meta {
    display: flex;
    justify-content: space-between;
    font-size: var(--t-body-s);
    color: color-mix(in srgb, var(--paper) 70%, transparent);
  }

  @media (max-width: 640px) {
    .site-footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
    .site-footer__contact {
      align-items: flex-start;
      text-align: left;
    }
    .wordmark--large {
      font-size: 32px;
    }
    .site-footer__meta {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
