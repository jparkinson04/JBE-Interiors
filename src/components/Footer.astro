---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__row">
      <a href="/" class="site-footer__logo" aria-label="JBE Interiors — home">
        <img
          src="/assets/jbe-badge.jpg"
          alt="JBE Interiors"
          width="447"
          height="447"
          class="site-footer__logo-img"
        />
      </a>

      <address class="site-footer__contact">
        <a href="tel:+441302322202">01302&nbsp;322&nbsp;202</a>
        <span class="site-footer__dot" aria-hidden="true">·</span>
        <a href="mailto:jason@jbeinteriors.com">jason@jbeinteriors.com</a>
        <span class="site-footer__dot" aria-hidden="true">·</span>
        <span>305 Churchway, Doncaster, DN1&nbsp;2TB</span>
      </address>

      <nav class="site-footer__social" aria-label="Social channels">
        <a
          href="https://www.instagram.com/jbeinteriorsltd/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram — @jbeinteriorsltd"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/company/jbe-interiors/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn — JBE Interiors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.26 2.37 4.26 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
          </svg>
        </a>
      </nav>
    </div>

    <hr class="site-footer__rule" />

    <div class="site-footer__meta">
      <span>&copy; JBE Interiors Ltd {year}</span>
      <span>
        Site by
        <a href="https://www.seamdigitalstudio.com/" target="_blank" rel="noopener noreferrer">SEAM</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--paper);
    padding-block: var(--space-l);
  }

  .site-footer__inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  /* Single compact row: small logo · inline contact · social icons. */
  .site-footer__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  .site-footer__logo {
    color: var(--paper);
    flex-shrink: 0;
  }

  .site-footer__logo-img {
    height: 40px;
    width: auto;
    display: block;
  }

  .site-footer__contact {
    font-style: normal;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    font-size: var(--t-body-m);
    color: color-mix(in srgb, var(--paper) 85%, transparent);
  }

  .site-footer__contact a:hover {
    color: var(--accent);
  }

  .site-footer__dot {
    color: color-mix(in srgb, var(--paper) 35%, transparent);
  }

  .site-footer__social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-m);
    flex-shrink: 0;
  }

  .site-footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--paper);
  }

  .site-footer__social svg {
    width: 20px;
    height: 20px;
  }

  .site-footer__social a:hover {
    color: var(--accent);
  }

  .site-footer__rule {
    margin: var(--space-m) 0 var(--space-s);
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--paper) 16%, transparent);
  }

  .site-footer__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-m);
    font-size: var(--t-body-s);
    color: color-mix(in srgb, var(--paper) 65%, transparent);
  }

  .site-footer__meta a {
    color: var(--paper);
    border-bottom: 1px solid color-mix(in srgb, var(--paper) 22%, transparent);
    padding-bottom: 1px;
  }

  .site-footer__meta a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 768px) {
    .site-footer__row {
      gap: var(--space-s);
    }
    .site-footer__contact {
      order: 3;
      width: 100%;
      justify-content: flex-start;
    }
    .site-footer__meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }
  }
</style>
