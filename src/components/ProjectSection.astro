---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  index: number;
}

const { project, index } = Astro.props;
const { data } = project;
const number = String(index + 1).padStart(2, '0');

const categoryLabel = data.category === 'hospitality-group'
  ? 'Hospitality Group'
  : data.category.charAt(0).toUpperCase() + data.category.slice(1);

const meta = [
  data.client ? { label: 'Client', value: data.client } : null,
  data.location ? { label: 'Location', value: data.location } : null,
  data.programme ? { label: 'Programme', value: data.programme } : null,
  data.budget ? { label: 'Build cost', value: data.budget } : null,
  data.designer ? { label: 'Design', value: data.designer } : null,
  data.year ? { label: 'Year', value: String(data.year) } : null,
].filter((m): m is { label: string; value: string } => m !== null);
---

<article class="project" id={data.slug}>
  <figure class="project__hero">
    <img
      src={data.hero_image}
      alt={`${data.name} — interior view`}
      loading={index === 0 ? 'eager' : 'lazy'}
      decoding="async"
    />
  </figure>

  <div class="project__container">
    <header class="project__header">
      <p class="eyebrow">{number} / {categoryLabel}</p>
      <h2 class="project__name">{data.name}</h2>
    </header>

    <div class="project__body">
      <div class="project__description">
        {data.description.split(/\n\n+/).filter(Boolean).map((para) => (
          <p>{para.trim()}</p>
        ))}

        {data.features.length > 0 && (
          <div class="project__features">
            <p class="eyebrow">Key features</p>
            <ul role="list">
              {data.features.map((f) => <li>{f}</li>)}
            </ul>
          </div>
        )}
      </div>

      <dl class="project__meta">
        {meta.map((m) => (
          <div class="project__meta-row">
            <dt class="eyebrow">{m.label}</dt>
            <dd>{m.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    {data.gallery.length > 0 && (
      <div class="project__gallery">
        {data.gallery.map((img) => (
          <figure>
            <img src={img.image} alt={img.caption ?? `${data.name} detail`} loading="lazy" decoding="async" />
            {img.caption && <figcaption>{img.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}
  </div>
</article>

<style>
  .project {
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--bone);
  }

  .project:last-of-type {
    border-bottom: 0;
  }

  .project__hero {
    margin: 0 0 var(--space-xl);
    aspect-ratio: 16 / 10;
    max-height: 75vh;
    overflow: hidden;
  }

  .project__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .project__container {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .project__header {
    margin-bottom: var(--space-l);
    max-width: 880px;
  }

  .project__name {
    font-size: var(--t-display-m);
    font-weight: 300;
    letter-spacing: var(--ls-display);
    line-height: var(--lh-display);
    color: var(--ink);
    margin-top: var(--space-s);
  }

  .project__body {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 3fr);
    gap: var(--space-2xl);
    align-items: start;
  }

  .project__description {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .project__description p {
    font-size: var(--t-body-l);
    color: var(--ink);
    line-height: var(--lh-body);
    max-width: 62ch;
  }

  .project__features {
    margin-top: var(--space-s);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .project__features ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .project__features li {
    font-size: var(--t-body-m);
    color: var(--ink);
    padding-left: 22px;
    position: relative;
  }

  .project__features li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 12px;
    height: 1px;
    background: var(--slate);
  }

  .project__meta {
    margin: 0;
    padding: var(--space-m) 0 0;
    border-top: 1px solid var(--bone);
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .project__meta-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .project__meta-row dd {
    margin: 0;
    font-size: var(--t-body-m);
    color: var(--ink);
  }

  .project__gallery {
    margin-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .project__gallery figure {
    margin: 0;
  }

  .project__gallery img {
    width: 100%;
    height: auto;
    display: block;
  }

  .project__gallery figcaption {
    margin-top: var(--space-s);
    font-size: var(--t-caption);
    color: var(--slate);
    line-height: var(--lh-caption);
  }

  @media (max-width: 960px) {
    .project__body {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
    .project__meta {
      padding-top: var(--space-l);
    }
    .project__hero {
      aspect-ratio: 4 / 3;
    }
  }
</style>
