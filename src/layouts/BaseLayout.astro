---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'JBE Interiors — restaurant and retail fit-outs across the UK, Ireland, and Jersey.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500&display=swap"
    />

    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main class="page-enter" id="main">
      <slot />
    </main>
    <Footer />

    <style>
      main {
        padding-top: var(--header-height);
        min-height: calc(100vh - var(--header-height));
      }
    </style>

    <script>
      import Lenis from 'lenis';

      /* Inertial smooth-scroll. Skipped for visitors who've opted into
         reduced motion — they get native browser scrolling instead. */
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReduced) {
        const lenis = new Lenis({
          /* lerp = framewise interpolation toward the target scroll position.
             Higher = snappier response; lower = longer glide. 0.12 feels
             responsive while still gliding through inertia. */
          lerp: 0.12,
          smoothWheel: true,
          wheelMultiplier: 1.1,
          touchMultiplier: 1.8,
        });

        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);

        /* Anchor links use Lenis's own scrollTo so the easing matches. */
        document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const id = a.getAttribute('href')?.slice(1);
            if (!id) return;
            const target = document.getElementById(id);
            if (target) {
              e.preventDefault();
              lenis.scrollTo(target, { offset: -80 });
            }
          });
        });
      }
    </script>
  </body>
</html>
