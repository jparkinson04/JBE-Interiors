---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

/* Each card cycles through the hero plus the first three gallery images
   so visitors get a quick taste of each project from the index. All
   cards advance in lockstep — same animation duration, same per-index
   delay across every card, so the grid reads as a synchronised
   editorial spread, not four independent banners. */
const CYCLE_SECONDS = 5;
const SLIDES_PER_CARD = 4;
const TOTAL_SECONDS = CYCLE_SECONDS * SLIDES_PER_CARD;

function cardSlides(hero: string, gallery: { image: string }[]): string[] {
  const slides = [hero, ...gallery.map((g) => g.image)];
  return slides.slice(0, SLIDES_PER_CARD);
}
---

<BaseLayout title="Projects — JBE Interiors">
  <section class="projects-page__intro">
    <div class="projects-page__intro-inner">
      <p class="eyebrow">Projects</p>
      <h1>Selected projects.</h1>
      <p class="projects-page__lead">
        A curated selection of recent restaurant and retail fit-outs.
        Delivered nationwide for national chains, hospitality groups, and
        independent operators.
      </p>
    </div>
  </section>

  <section class="projects-page__list" aria-label="Projects">
    <div class="projects-page__list-inner">
      <ul class="projects-page__grid" role="list">
        {projects.map((project, i) => {
          const slides = cardSlides(project.data.hero_image, project.data.gallery);
          return (
            <li class="project-card">
              <a href={`/projects/${project.data.slug}`} class="project-card__link">
                <figure class="project-card__media" aria-hidden="false">
                  {slides.map((src, slideIdx) => (
                    <img
                      class="project-card__slide"
                      src={src}
                      alt={slideIdx === 0 ? `${project.data.name} — interior view` : ''}
                      loading={i < 2 && slideIdx === 0 ? 'eager' : 'lazy'}
                      fetchpriority={i === 0 && slideIdx === 0 ? 'high' : 'auto'}
                      decoding="async"
                      style={`--slide-delay: ${-(TOTAL_SECONDS - slideIdx * CYCLE_SECONDS)}s;`}
                    />
                  ))}
                </figure>
                <div class="project-card__body">
                  <h2 class="project-card__name">{project.data.name}</h2>
                  <p class="project-card__location">{project.data.location}</p>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <section class="projects-page__more">
    <div class="projects-page__more-inner">
      <p class="eyebrow">More</p>
      <p class="projects-page__more-text">
        Selected projects shown. The full portfolio is available on request.
      </p>
      <a href="/contact" class="btn btn--secondary">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<style define:vars={{ totalSeconds: `${TOTAL_SECONDS}s` }}>
  .projects-page__intro {
    background: var(--paper);
    padding-block: var(--space-l) var(--space-m);
  }

  .projects-page__intro-inner {
    max-width: 980px;
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .projects-page__intro h1 {
    font-size: var(--t-display-l);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
    margin-top: var(--space-s);
  }

  .projects-page__lead {
    margin-top: var(--space-m);
    font-size: var(--t-body-l);
    color: var(--slate);
    max-width: 56ch;
    line-height: var(--lh-body);
  }

  .projects-page__list {
    padding-block: var(--space-m) var(--space-l);
  }

  .projects-page__list-inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  /* Two columns gives each project enough presence to read as a feature
     card. Names sit larger, photographs do the talking. */
  .projects-page__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--grid-gutter);
    row-gap: var(--space-l);
  }

  .project-card {
    display: block;
  }

  .project-card__link {
    display: block;
    color: var(--ink);
    position: relative;
  }

  .project-card__media {
    margin: 0 0 var(--space-s);
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--stone);
    position: relative;
  }

  .project-card__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: 0;
    will-change: opacity;
  }

  /* First slide is opaque so the card never starts blank if the JS
     reduced-motion branch is taken or the animation is paused. */
  .project-card__slide:first-child {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .project-card__slide {
      animation: cardSlideShow var(--totalSeconds) cubic-bezier(0.45, 0, 0.55, 1) infinite;
      animation-delay: var(--slide-delay);
    }
    /* Subtle hover zoom over the entire stack; keeps the image lifting
       on interaction without breaking the synced timing. */
    .project-card__media {
      transition: transform 600ms var(--ease-out);
    }
    .project-card__link:hover .project-card__media,
    .project-card__link:focus-visible .project-card__media {
      transform: scale(1.012);
    }
  }

  @keyframes cardSlideShow {
    0%, 18.75% { opacity: 1; }
    25%, 93.75% { opacity: 0; }
    100% { opacity: 1; }
  }

  .project-card__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: var(--space-xs);
  }

  .project-card__name {
    font-family: var(--font-serif);
    font-size: clamp(26px, 2.4vw, 38px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
  }

  .project-card__location {
    font-size: var(--t-body-m);
    color: var(--slate);
  }

  .projects-page__more {
    background: var(--paper);
    padding-block: var(--space-l);
    border-top: 1px solid var(--bone);
  }

  .projects-page__more-inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-m);
  }

  .projects-page__more-text {
    font-size: var(--t-body-l);
    color: var(--ink);
    max-width: 52ch;
  }

  @media (max-width: 720px) {
    .projects-page__grid {
      grid-template-columns: 1fr;
      row-gap: var(--space-m);
    }
  }
</style>
