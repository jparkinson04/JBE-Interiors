---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

/* Each card shows three images — hero + first two gallery entries —
   with a small pair of arrow buttons in the bottom-right of the image.
   No auto-rotation; visitors flick through at their own pace. */
const SLIDES_PER_CARD = 3;

function cardSlides(hero: string, gallery: { image: string }[]): string[] {
  const slides = [hero, ...gallery.map((g) => g.image)];
  return slides.slice(0, SLIDES_PER_CARD);
}
---

<BaseLayout title="Projects — JBE Interiors">
  <section class="projects-page__intro">
    <div class="projects-page__intro-inner">
      <p class="eyebrow">Projects</p>
      <h1>Selected projects.</h1>
      <p class="projects-page__lead">
        A curated selection of recent restaurant and retail fit-outs.
        Delivered nationwide for national chains, hospitality groups, and
        independent operators.
      </p>
    </div>
  </section>

  <section class="projects-page__list" aria-label="Projects">
    <div class="projects-page__list-inner">
      <ul class="projects-page__grid" role="list">
        {projects.map((project, i) => {
          const slides = cardSlides(project.data.hero_image, project.data.gallery);
          return (
            <li class="project-card" data-card>
              <a href={`/projects/${project.data.slug}`} class="project-card__link">
                <figure class="project-card__media">
                  {slides.map((src, slideIdx) => (
                    <img
                      class={`project-card__slide${slideIdx === 0 ? ' is-active' : ''}`}
                      src={src}
                      alt={slideIdx === 0 ? `${project.data.name} — interior view` : ''}
                      loading={i < 2 && slideIdx === 0 ? 'eager' : 'lazy'}
                      fetchpriority={i === 0 && slideIdx === 0 ? 'high' : 'auto'}
                      decoding="async"
                    />
                  ))}
                </figure>
                <div class="project-card__body">
                  <h2 class="project-card__name">{project.data.name}</h2>
                  <p class="project-card__location">{project.data.location}</p>
                </div>
              </a>

              {slides.length > 1 && (
                <div class="project-card__controls" aria-hidden="false">
                  <span class="project-card__counter" data-counter>1 / {slides.length}</span>
                  <div class="project-card__nav">
                    <button
                      type="button"
                      class="project-card__nav-btn"
                      data-nav="prev"
                      aria-label={`Previous image for ${project.data.name}`}
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M15 6 9 12l6 6" />
                      </svg>
                    </button>
                    <button
                      type="button"
                      class="project-card__nav-btn"
                      data-nav="next"
                      aria-label={`Next image for ${project.data.name}`}
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M9 6 15 12l-6 6" />
                      </svg>
                    </button>
                  </div>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <section class="projects-page__more">
    <div class="projects-page__more-inner">
      <p class="eyebrow">More</p>
      <p class="projects-page__more-text">
        Selected projects shown. The full portfolio is available on request.
      </p>
      <a href="/contact" class="btn btn--secondary">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<script>
  /* Manual flick-through for each project card. No auto-cycle —
     visitors advance the carousel via the arrow buttons. Counter
     updates so visitors know how many shots remain. */
  document.querySelectorAll<HTMLElement>('[data-card]').forEach((card) => {
    const slides = card.querySelectorAll<HTMLElement>('.project-card__slide');
    const counter = card.querySelector<HTMLElement>('[data-counter]');
    const prev = card.querySelector<HTMLButtonElement>('[data-nav="prev"]');
    const next = card.querySelector<HTMLButtonElement>('[data-nav="next"]');
    if (slides.length < 2 || !prev || !next) return;

    let active = 0;
    const show = (i: number) => {
      active = (i + slides.length) % slides.length;
      slides.forEach((slide, idx) => slide.classList.toggle('is-active', idx === active));
      if (counter) counter.textContent = `${active + 1} / ${slides.length}`;
    };

    prev.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      show(active - 1);
    });
    next.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      show(active + 1);
    });
  });
</script>

<style>
  .projects-page__intro {
    background: var(--paper);
    padding-block: var(--space-l) var(--space-m);
  }

  .projects-page__intro-inner {
    max-width: 980px;
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .projects-page__intro h1 {
    font-size: var(--t-display-l);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
    margin-top: var(--space-s);
  }

  .projects-page__lead {
    margin-top: var(--space-m);
    font-size: var(--t-body-l);
    color: var(--slate);
    max-width: 56ch;
    line-height: var(--lh-body);
  }

  .projects-page__list {
    padding-block: var(--space-m) var(--space-l);
  }

  .projects-page__list-inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .projects-page__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--grid-gutter);
    row-gap: var(--space-l);
  }

  .project-card {
    display: block;
    position: relative;
  }

  .project-card__link {
    display: block;
    color: var(--ink);
    position: relative;
  }

  .project-card__media {
    margin: 0 0 var(--space-s);
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--stone);
    position: relative;
  }

  .project-card__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: 0;
    will-change: opacity;
  }

  @media (prefers-reduced-motion: no-preference) {
    .project-card__slide {
      transition: opacity 400ms var(--ease-out);
    }
  }

  .project-card__slide.is-active {
    opacity: 1;
  }

  /* Slide controls — sit over the bottom-right of the image as a small
     glass-paper bar. Counter on the left, two arrows on the right. */
  .project-card__controls {
    position: absolute;
    /* Anchor to image, not the body section below. */
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    /* Make the wrapper non-blocking; only the children catch pointer. */
    pointer-events: none;
  }

  .project-card__counter,
  .project-card__nav {
    pointer-events: auto;
  }

  .project-card__counter {
    position: absolute;
    bottom: calc(var(--space-s) + var(--space-s));
    left: var(--space-s);
    font-size: var(--t-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--paper);
    background: rgba(17, 17, 17, 0.55);
    backdrop-filter: blur(6px);
    padding: 4px 8px;
  }

  .project-card__nav {
    position: absolute;
    bottom: calc(var(--space-s) + var(--space-s));
    right: var(--space-s);
    display: flex;
    gap: 4px;
  }

  .project-card__nav-btn {
    width: 32px;
    height: 32px;
    background: rgba(247, 245, 240, 0.92);
    backdrop-filter: blur(6px);
    color: var(--ink);
    border: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .project-card__nav-btn {
      transition:
        background-color var(--motion-fast) ease,
        color var(--motion-fast) ease;
    }
  }

  .project-card__nav-btn:hover,
  .project-card__nav-btn:focus-visible {
    background: var(--ink);
    color: var(--paper);
  }

  .project-card__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: var(--space-xs);
  }

  .project-card__name {
    font-family: var(--font-serif);
    font-size: clamp(26px, 2.4vw, 38px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
  }

  .project-card__location {
    font-size: var(--t-body-m);
    color: var(--slate);
  }

  .projects-page__more {
    background: var(--paper);
    padding-block: var(--space-l);
    border-top: 1px solid var(--bone);
  }

  .projects-page__more-inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-m);
  }

  .projects-page__more-text {
    font-size: var(--t-body-l);
    color: var(--ink);
    max-width: 52ch;
  }

  @media (max-width: 720px) {
    .projects-page__grid {
      grid-template-columns: 1fr;
      row-gap: var(--space-m);
    }
  }
</style>
