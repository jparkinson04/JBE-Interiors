---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Projects — JBE Interiors">
  <section class="projects-page__intro">
    <div class="projects-page__intro-inner">
      <p class="eyebrow">Projects</p>
      <h1>Our work.</h1>
      <p class="projects-page__lead">
        A curated selection of recent restaurant and retail fit-outs.
        Delivered nationwide for national chains, hospitality groups, and
        independent operators.
      </p>
    </div>
  </section>

  <section class="projects-page__list" aria-label="Projects">
    <div class="projects-page__list-inner">
      <ul class="projects-page__grid" role="list">
        {projects.map((project, i) => (
          <li class="project-card">
            <a href={`/projects/${project.data.slug}`} class="project-card__link">
              <figure class="project-card__media">
                <img
                  src={project.data.hero_image}
                  alt={`${project.data.name} — interior view`}
                  width="1800"
                  height="1350"
                  loading={i < 4 ? 'eager' : 'lazy'}
                  fetchpriority={i === 0 ? 'high' : 'auto'}
                  decoding="async"
                />
              </figure>
              <div class="project-card__body">
                <h2 class="project-card__name">{project.data.name}</h2>
                <p class="project-card__location">{project.data.location}</p>
                <span class="project-card__cta">Click here for more information &rarr;</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</BaseLayout>

<script>
  /* Fade in card images that are still downloading when the page
     arrives, instead of letting them pop in half-decoded. Images
     already complete (cache hits) show immediately. */
  document.querySelectorAll<HTMLImageElement>('.project-card__media img').forEach((img) => {
    if (img.complete) return;
    img.classList.add('will-fade');
    img.addEventListener(
      'load',
      () => img.classList.add('is-loaded'),
      { once: true }
    );
  });
</script>

<style>
  .projects-page__intro {
    background: var(--paper);
    padding-block: var(--space-l) var(--space-m);
  }

  .projects-page__intro-inner {
    max-width: 980px;
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .projects-page__intro h1 {
    font-size: var(--t-display-l);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
    margin-top: var(--space-s);
  }

  .projects-page__lead {
    margin-top: var(--space-m);
    font-size: var(--t-body-l);
    color: var(--slate);
    max-width: 56ch;
    line-height: var(--lh-body);
  }

  .projects-page__list {
    padding-block: var(--space-m) var(--space-l);
  }

  .projects-page__list-inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .projects-page__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--grid-gutter);
    row-gap: var(--space-l);
  }

  .project-card {
    display: block;
    position: relative;
  }

  .project-card__link {
    display: block;
    color: var(--ink);
    position: relative;
  }

  .project-card__media {
    margin: 0 0 var(--space-s);
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--stone);
  }

  .project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .project-card__media img {
      transition:
        transform 600ms var(--ease-out),
        opacity 400ms ease;
    }
    .project-card__link:hover .project-card__media img,
    .project-card__link:focus-visible .project-card__media img {
      transform: scale(1.02);
    }
    /* Images still downloading when the page arrives are hidden by the
       load-fade script (adds .will-fade, then .is-loaded on load), so
       they fade in over the stone placeholder instead of popping in
       half-decoded. No-JS or reduced-motion: images just show. */
    .project-card__media img.will-fade {
      opacity: 0;
    }
    .project-card__media img.will-fade.is-loaded {
      opacity: 1;
    }
  }

  .project-card__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: var(--space-xs);
  }

  .project-card__name {
    font-family: var(--font-serif);
    font-size: clamp(22px, 2.4vw, 38px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--ink);
    /* Long project names (e.g. "Wagamama Central Production Unit,
       Acton") wrap cleanly without producing wide overflowing words. */
    overflow-wrap: balance;
    text-wrap: balance;
  }

  .project-card__location {
    font-size: var(--t-body-m);
    color: var(--slate);
  }

  /* Explicit CTA replacing the flick-through arrows. */
  .project-card__cta {
    margin-top: var(--space-xs);
    align-self: flex-start;
    font-size: var(--t-body-s);
    font-weight: 500;
    letter-spacing: var(--ls-button);
    text-transform: uppercase;
    color: var(--ink);
    border-bottom: 1px solid var(--bone);
    padding-bottom: 2px;
  }

  .project-card__link:hover .project-card__cta,
  .project-card__link:focus-visible .project-card__cta {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }


  @media (max-width: 720px) {
    .projects-page__grid {
      grid-template-columns: 1fr;
      row-gap: var(--space-m);
    }
  }
</style>
