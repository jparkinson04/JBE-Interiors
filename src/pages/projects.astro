---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

const categoryLabel = (cat: string) =>
  cat === 'hospitality-group'
    ? 'Hospitality Group'
    : cat.charAt(0).toUpperCase() + cat.slice(1);
---

<BaseLayout title="Projects — JBE Interiors">
  <section class="projects-page__intro">
    <div class="projects-page__intro-inner">
      <p class="eyebrow">Work</p>
      <h1>Selected projects.</h1>
      <p class="projects-page__lead">
        A curated selection of recent restaurant and retail fit-outs.
        Delivered nationwide for national chains, hospitality groups, and
        independent operators.
      </p>
    </div>
  </section>

  <section class="projects-page__list" aria-label="Projects">
    <div class="projects-page__list-inner">
      <ul class="projects-page__grid" role="list">
        {projects.map((project, i) => {
          const { data } = project;
          const number = String(i + 1).padStart(2, '0');
          return (
            <li class="project-card">
              <a href={`/projects/${data.slug}`} class="project-card__link">
                <figure class="project-card__media">
                  <img
                    src={data.hero_image}
                    alt={`${data.name} — interior view`}
                    loading={i < 2 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </figure>
                <div class="project-card__body">
                  <p class="eyebrow">{number} / {categoryLabel(data.category)}</p>
                  <h2 class="project-card__name">{data.name}</h2>
                  <p class="project-card__location">{data.location}</p>
                </div>
                <span class="project-card__arrow" aria-hidden="true">View project &rarr;</span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  <section class="projects-page__more">
    <div class="projects-page__more-inner">
      <p class="eyebrow">More</p>
      <p class="projects-page__more-text">
        Selected projects shown. The full portfolio is available on request.
      </p>
      <a href="/contact" class="btn btn--secondary">Get in touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .projects-page__intro {
    background: var(--paper);
    padding-block: var(--space-xl) var(--space-l);
  }

  .projects-page__intro-inner {
    max-width: 980px;
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .projects-page__intro h1 {
    font-size: var(--t-display-l);
    font-weight: 300;
    letter-spacing: var(--ls-display);
    line-height: var(--lh-display);
    color: var(--ink);
    margin-top: var(--space-s);
  }

  .projects-page__lead {
    margin-top: var(--space-m);
    font-size: var(--t-body-l);
    color: var(--slate);
    max-width: 56ch;
    line-height: var(--lh-body);
  }

  .projects-page__list {
    padding-block: var(--space-l) var(--space-2xl);
  }

  .projects-page__list-inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .projects-page__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--grid-gutter);
    row-gap: var(--space-xl);
  }

  .project-card {
    display: block;
  }

  .project-card__link {
    display: block;
    color: var(--ink);
    position: relative;
  }

  .project-card__media {
    margin: 0 0 var(--space-m);
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--stone);
  }

  .project-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .project-card__media img {
      transition: transform 600ms var(--ease-out), opacity 200ms ease;
    }
    .project-card__link:hover .project-card__media img,
    .project-card__link:focus-visible .project-card__media img {
      transform: scale(1.02);
    }
  }

  .project-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .project-card__name {
    font-size: var(--t-display-m);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    margin-top: 4px;
  }

  .project-card__location {
    font-size: var(--t-body-m);
    color: var(--slate);
  }

  .project-card__arrow {
    display: inline-block;
    margin-top: var(--space-s);
    font-size: var(--t-body-s);
    font-weight: 500;
    letter-spacing: var(--ls-button);
    text-transform: uppercase;
    color: var(--ink);
    border-bottom: 1px solid var(--bone);
    padding-bottom: 2px;
  }

  .project-card__link:hover .project-card__arrow,
  .project-card__link:focus-visible .project-card__arrow {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* Stagger the cards visually: every 4th card is offset down so the grid
     reads as an editorial sequence rather than a uniform tile pattern. */
  @media (min-width: 961px) {
    .project-card:nth-child(2n) {
      transform: translateY(var(--space-l));
    }
  }

  .projects-page__more {
    background: var(--paper);
    padding-block: var(--space-2xl);
    border-top: 1px solid var(--bone);
  }

  .projects-page__more-inner {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-m);
  }

  .projects-page__more-text {
    font-size: var(--t-body-l);
    color: var(--ink);
    max-width: 52ch;
  }

  @media (max-width: 960px) {
    .projects-page__grid {
      grid-template-columns: 1fr;
      row-gap: var(--space-l);
    }
  }
</style>
