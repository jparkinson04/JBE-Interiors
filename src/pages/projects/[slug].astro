---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;

const sorted = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
const currentIdx = sorted.findIndex((p) => p.data.slug === data.slug);
const prev = sorted[(currentIdx - 1 + sorted.length) % sorted.length];
const next = sorted[(currentIdx + 1) % sorted.length];

const categoryLabel =
  data.category === 'hospitality-group'
    ? 'Hospitality Group'
    : data.category.charAt(0).toUpperCase() + data.category.slice(1);

const meta = [
  data.client ? { label: 'Client', value: data.client } : null,
  data.location ? { label: 'Location', value: data.location } : null,
  data.programme ? { label: 'Programme', value: data.programme } : null,
  data.budget ? { label: 'Build cost', value: data.budget } : null,
  data.designer ? { label: 'Design', value: data.designer } : null,
  data.year ? { label: 'Year', value: String(data.year) } : null,
].filter((m): m is { label: string; value: string } => m !== null);
---

<BaseLayout title={`${data.name} — JBE Interiors`} description={data.description.slice(0, 150)}>
  <article class="project-detail">
    <div class="project-detail__container">
      <div class="project-detail__top">
        <div class="project-detail__intro">
          <header class="project-detail__header">
            <p class="eyebrow">{categoryLabel}</p>
            <h1 class="project-detail__name">{data.name}</h1>
          </header>

          {data.description && (
            <p class="project-detail__lead">{data.description.trim()}</p>
          )}
        </div>

        <figure class="project-detail__hero">
          <img
            src={data.hero_image}
            alt={`${data.name} — interior view`}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </figure>
      </div>

      {meta.length > 0 && (
        <dl class="project-detail__meta">
          {meta.map((m) => (
            <div class="project-detail__meta-tile">
              <dt class="eyebrow">{m.label}</dt>
              <dd>{m.value}</dd>
            </div>
          ))}
        </dl>
      )}

      {(data.sections.length > 0 || data.features.length > 0) && (
        <div class="project-detail__sections">
          {data.sections.map((section) => (
            <section class="project-detail__section">
              <h2 class="project-detail__section-heading">{section.heading}</h2>
              <div class="project-detail__section-body">
                {section.paragraphs.map((para) => (
                  <p>{para}</p>
                ))}
                {section.bullets.length > 0 && (
                  <ul class="project-detail__bullets" role="list">
                    {section.bullets.map((b) => <li>{b}</li>)}
                  </ul>
                )}
              </div>
            </section>
          ))}

          {data.features.length > 0 && (
            <section class="project-detail__section">
              <h2 class="project-detail__section-heading">Key features</h2>
              <div class="project-detail__section-body">
                <ul class="project-detail__bullets" role="list">
                  {data.features.map((f) => <li>{f}</li>)}
                </ul>
              </div>
            </section>
          )}
        </div>
      )}

      {data.gallery.length > 0 && (
        <section class="project-detail__gallery" aria-label="Project gallery">
          {data.gallery.map((img) => (
            <figure>
              <img
                src={img.image}
                alt={img.caption ?? `${data.name} detail`}
                loading="eager"
                decoding="async"
              />
              {img.caption && <figcaption>{img.caption}</figcaption>}
            </figure>
          ))}
        </section>
      )}

      <nav class="project-detail__nav" aria-label="Project navigation">
        <a href={`/projects/${prev.data.slug}`} class="project-detail__nav-link project-detail__nav-link--prev">
          <span class="eyebrow">Previous</span>
          <span class="project-detail__nav-name">{prev.data.name}</span>
        </a>
        <a href="/projects" class="project-detail__nav-link project-detail__nav-link--index">
          <span class="eyebrow">All work</span>
        </a>
        <a href={`/projects/${next.data.slug}`} class="project-detail__nav-link project-detail__nav-link--next">
          <span class="eyebrow">Next</span>
          <span class="project-detail__nav-name">{next.data.name}</span>
        </a>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    /* Breathing room between the fixed header bar and the page top. */
    padding-top: var(--space-m);
    padding-bottom: var(--space-l);
  }

  .project-detail__container {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  /* Opening split: title + lead beside the hero image rather than
     beneath a full-width banner. Intro column left, photograph right. */
  .project-detail__top {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: var(--space-xl);
    align-items: center;
    margin-bottom: var(--space-m);
  }

  .project-detail__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .project-detail__hero {
    margin: 0;
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .project-detail__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .project-detail__name {
    font-size: var(--t-display-l);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--ink);
    margin-top: var(--space-xs);
    text-wrap: balance;
  }

  /* Meta tile grid — small stone-toned boxes sit directly under the
     project name so all the key details are visible immediately, no
     scroll required. Each tile is its own card, not a row of values. */
  .project-detail__meta {
    margin: 0 0 var(--space-m);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-s);
  }

  .project-detail__meta-tile {
    background: var(--stone);
    padding: var(--space-m);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    /* Subtle terracotta seam on the left of each tile — editorial
       callout mark without being noisy. */
    border-left: 2px solid var(--accent);
  }

  .project-detail__meta-tile dt {
    margin: 0;
  }

  .project-detail__meta-tile dd {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(18px, 1.4vw, 24px);
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  /* Lead paragraph (the card summary) — sits under the title in the
     opening split's intro column. */
  .project-detail__lead {
    margin: 0;
    font-size: var(--t-body-l);
    color: var(--slate);
    line-height: var(--lh-body);
    max-width: 44ch;
  }

  /* Body sections — a clean editorial ledger: heading in the left
     column, copy in the right, thin rules between rows. Same layout
     language as the About section; no boxes, no numbering. */
  .project-detail__sections {
    border-top: 1px solid var(--bone);
    margin-bottom: var(--space-l);
  }

  .project-detail__section {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
    gap: var(--space-l);
    padding-block: var(--space-m);
    border-bottom: 1px solid var(--bone);
    align-items: start;
  }

  .project-detail__section-heading {
    font-family: var(--font-serif);
    font-size: clamp(20px, 1.7vw, 26px);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
    max-width: 20ch;
  }

  .project-detail__section-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .project-detail__section-body p {
    font-size: var(--t-body-m);
    color: var(--ink);
    line-height: var(--lh-body);
    max-width: 66ch;
  }

  .project-detail__bullets {
    list-style: none;
    margin: var(--space-xs) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    max-width: 70ch;
  }

  .project-detail__bullets li {
    font-size: var(--t-body-m);
    color: var(--ink);
    line-height: var(--lh-body);
    padding-left: 22px;
    position: relative;
  }

  .project-detail__bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 12px;
    height: 1px;
    background: var(--accent);
  }

  /* Gallery — 2-column grid (responsive), uniform 4:3 tiles. Every 5th
     tile spans wide for editorial rhythm. */
  .project-detail__gallery {
    margin-top: var(--space-l);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-s);
  }

  .project-detail__gallery figure {
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .project-detail__gallery img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Load fade — see the script at the bottom of this file. */
  @media (prefers-reduced-motion: no-preference) {
    .project-detail__gallery img,
    .project-detail__hero img {
      transition: opacity 400ms ease;
    }
    .project-detail__gallery img.will-fade,
    .project-detail__hero img.will-fade {
      opacity: 0;
    }
    .project-detail__gallery img.will-fade.is-loaded,
    .project-detail__hero img.will-fade.is-loaded {
      opacity: 1;
    }
  }

  .project-detail__gallery figcaption {
    margin-top: var(--space-xs);
    font-size: var(--t-caption);
    color: var(--slate);
    line-height: var(--lh-caption);
  }

  @media (min-width: 720px) {
    .project-detail__gallery figure:nth-child(5n + 1) {
      grid-column: span 2;
      aspect-ratio: 21 / 9;
    }

    /* A trailing image that would sit alone (leaving an empty cell
       bottom-right) stretches across both columns instead. With the
       5n+1 full-width rhythm above, the lone-tile cases are exactly
       last children at positions 5n+2 and 5n+4. */
    .project-detail__gallery figure:last-child:nth-child(5n + 2),
    .project-detail__gallery figure:last-child:nth-child(5n + 4) {
      grid-column: span 2;
      aspect-ratio: 21 / 9;
    }
  }

  .project-detail__nav {
    margin-top: var(--space-l);
    padding-top: var(--space-m);
    border-top: 1px solid var(--bone);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-m);
    align-items: center;
  }

  .project-detail__nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: var(--ink);
  }

  .project-detail__nav-link:hover {
    color: var(--accent);
  }

  .project-detail__nav-link--next {
    text-align: right;
    align-items: flex-end;
  }

  .project-detail__nav-link--index {
    text-align: center;
    align-items: center;
  }

  .project-detail__nav-name {
    font-size: var(--t-body-m);
    font-weight: 400;
  }

  @media (max-width: 720px) {
    /* Stack the opening split: title above, image below. */
    .project-detail__top {
      grid-template-columns: 1fr;
      gap: var(--space-m);
      margin-bottom: var(--space-m);
    }
    .project-detail__hero {
      aspect-ratio: 4 / 3;
    }
    .project-detail__meta {
      grid-template-columns: 1fr 1fr;
    }
    /* Ledger rows stack: heading above its copy. */
    .project-detail__section {
      grid-template-columns: 1fr;
      gap: var(--space-s);
    }
    .project-detail__gallery {
      grid-template-columns: 1fr;
    }
    .project-detail__nav {
      grid-template-columns: 1fr;
      gap: var(--space-s);
    }
    .project-detail__nav-link--next {
      text-align: left;
      align-items: flex-end;
    }
    .project-detail__nav-link--index {
      text-align: left;
      align-items: flex-start;
    }
  }

  /* Narrow mobile: 2-col meta tiles squish addresses awkwardly.
     Drop to a single column so values read cleanly. */
  @media (max-width: 480px) {
    .project-detail__meta {
      grid-template-columns: 1fr;
    }
    .project-detail__container {
      padding-top: var(--space-m);
    }
    .project-detail__header {
      margin-bottom: var(--space-s);
    }
  }
</style>

<script>
  /* Fade in hero/gallery images that are still downloading when the
     page arrives; cache hits show immediately. */
  document
    .querySelectorAll<HTMLImageElement>('.project-detail__gallery img, .project-detail__hero img')
    .forEach((img) => {
      if (img.complete) return;
      img.classList.add('will-fade');
      img.addEventListener('load', () => img.classList.add('is-loaded'), { once: true });
    });
</script>
