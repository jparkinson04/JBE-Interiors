---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;

const sorted = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
const currentIdx = sorted.findIndex((p) => p.data.slug === data.slug);
const prev = sorted[(currentIdx - 1 + sorted.length) % sorted.length];
const next = sorted[(currentIdx + 1) % sorted.length];

const categoryLabel =
  data.category === 'hospitality-group'
    ? 'Hospitality Group'
    : data.category.charAt(0).toUpperCase() + data.category.slice(1);

const meta = [
  data.client ? { label: 'Client', value: data.client } : null,
  data.location ? { label: 'Location', value: data.location } : null,
  data.programme ? { label: 'Programme', value: data.programme } : null,
  data.budget ? { label: 'Build cost', value: data.budget } : null,
  data.designer ? { label: 'Design', value: data.designer } : null,
  data.year ? { label: 'Year', value: String(data.year) } : null,
].filter((m): m is { label: string; value: string } => m !== null);
---

<BaseLayout title={`${data.name} — JBE Interiors`} description={data.description.slice(0, 150)}>
  <article class="project-detail">
    <figure class="project-detail__hero">
      <img
        src={data.hero_image}
        alt={`${data.name} — interior view`}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </figure>

    <div class="project-detail__container">
      <header class="project-detail__header">
        <p class="eyebrow">{categoryLabel}</p>
        <h1 class="project-detail__name">{data.name}</h1>
      </header>

      {meta.length > 0 && (
        <dl class="project-detail__meta">
          {meta.map((m) => (
            <div class="project-detail__meta-tile">
              <dt class="eyebrow">{m.label}</dt>
              <dd>{m.value}</dd>
            </div>
          ))}
        </dl>
      )}

      {data.description && (
        <p class="project-detail__lead">{data.description.trim()}</p>
      )}

      {data.sections.length > 0 && (
        <div class="project-detail__sections">
          {data.sections.map((section, idx) => (
            <section class="project-detail__section">
              <header class="project-detail__section-head">
                <span class="project-detail__section-number">
                  {String(idx + 1).padStart(2, '0')}
                </span>
                <h2 class="project-detail__section-heading">{section.heading}</h2>
              </header>
              {section.paragraphs.map((para) => (
                <p>{para}</p>
              ))}
              {section.bullets.length > 0 && (
                <ul class="project-detail__bullets" role="list">
                  {section.bullets.map((b) => <li>{b}</li>)}
                </ul>
              )}
            </section>
          ))}
        </div>
      )}

      {data.features.length > 0 && (
        <section class="project-detail__section project-detail__section--features">
          <header class="project-detail__section-head">
            <span class="project-detail__section-number" aria-hidden="true">&mdash;</span>
            <h2 class="project-detail__section-heading">Key features</h2>
          </header>
          <ul class="project-detail__bullets" role="list">
            {data.features.map((f) => <li>{f}</li>)}
          </ul>
        </section>
      )}

      {data.gallery.length > 0 && (
        <section class="project-detail__gallery" aria-label="Project gallery">
          {data.gallery.map((img) => (
            <figure>
              <img
                src={img.image}
                alt={img.caption ?? `${data.name} detail`}
                loading="lazy"
                decoding="async"
              />
              {img.caption && <figcaption>{img.caption}</figcaption>}
            </figure>
          ))}
        </section>
      )}

      <nav class="project-detail__nav" aria-label="Project navigation">
        <a href={`/projects/${prev.data.slug}`} class="project-detail__nav-link project-detail__nav-link--prev">
          <span class="eyebrow">Previous</span>
          <span class="project-detail__nav-name">{prev.data.name}</span>
        </a>
        <a href="/projects" class="project-detail__nav-link project-detail__nav-link--index">
          <span class="eyebrow">All work</span>
        </a>
        <a href={`/projects/${next.data.slug}`} class="project-detail__nav-link project-detail__nav-link--next">
          <span class="eyebrow">Next</span>
          <span class="project-detail__nav-name">{next.data.name}</span>
        </a>
      </nav>
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    padding-bottom: var(--space-l);
  }

  /* Hero — wide-cinematic ratio. Doesn't dominate above-the-fold. */
  .project-detail__hero {
    margin: 0;
    aspect-ratio: 21 / 9;
    max-height: 48vh;
    overflow: hidden;
  }

  .project-detail__hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .project-detail__container {
    max-width: var(--grid-max);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    padding-top: var(--space-l);
  }

  .project-detail__header {
    max-width: 880px;
    margin-bottom: var(--space-m);
  }

  .project-detail__name {
    font-size: var(--t-display-l);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
    margin-top: var(--space-xs);
  }

  /* Meta tile grid — small stone-toned boxes sit directly under the
     project name so all the key details are visible immediately, no
     scroll required. Each tile is its own card, not a row of values. */
  .project-detail__meta {
    margin: 0 0 var(--space-l);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-s);
  }

  .project-detail__meta-tile {
    background: var(--stone);
    padding: var(--space-m);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    /* Subtle terracotta seam on the left of each tile — editorial
       callout mark without being noisy. */
    border-left: 2px solid var(--accent);
  }

  .project-detail__meta-tile dt {
    margin: 0;
  }

  .project-detail__meta-tile dd {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(18px, 1.4vw, 24px);
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  /* Lead paragraph (the card summary). Upright sans body-l, not italic
     — reads as a clear intro line, not a flourish. */
  .project-detail__lead {
    max-width: 720px;
    margin: 0 0 var(--space-l);
    font-size: var(--t-body-l);
    color: var(--ink);
    line-height: var(--lh-body);
  }

  /* Body sections — each rendered as its own warm stone box. Number
     marker + heading at top, then paragraphs and any bullets. Gap
     between boxes gives breathing room without crowding. */
  .project-detail__sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    max-width: 920px;
  }

  .project-detail__section {
    background: var(--stone);
    padding: var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .project-detail__section--features {
    margin-top: var(--space-m);
    max-width: 920px;
  }

  .project-detail__section-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-s);
    margin-bottom: 4px;
  }

  .project-detail__section-number {
    font-family: var(--font-serif);
    font-size: clamp(15px, 1vw, 18px);
    font-weight: 400;
    font-style: italic;
    color: var(--accent);
    line-height: 1;
    flex-shrink: 0;
  }

  .project-detail__section-heading {
    font-family: var(--font-serif);
    font-size: clamp(22px, 1.8vw, 28px);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.15;
    color: var(--ink);
    margin: 0;
  }

  .project-detail__section p {
    font-size: var(--t-body-m);
    color: var(--ink);
    line-height: var(--lh-body);
    max-width: 70ch;
  }

  .project-detail__bullets {
    list-style: none;
    margin: var(--space-xs) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    max-width: 70ch;
  }

  .project-detail__bullets li {
    font-size: var(--t-body-m);
    color: var(--ink);
    line-height: var(--lh-body);
    padding-left: 22px;
    position: relative;
  }

  .project-detail__bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 12px;
    height: 1px;
    background: var(--accent);
  }

  /* Gallery — 2-column grid (responsive), uniform 4:3 tiles. Every 5th
     tile spans wide for editorial rhythm. */
  .project-detail__gallery {
    margin-top: var(--space-l);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-s);
  }

  .project-detail__gallery figure {
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .project-detail__gallery img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .project-detail__gallery figcaption {
    margin-top: var(--space-xs);
    font-size: var(--t-caption);
    color: var(--slate);
    line-height: var(--lh-caption);
  }

  @media (min-width: 720px) {
    .project-detail__gallery figure:nth-child(5n + 1) {
      grid-column: span 2;
      aspect-ratio: 21 / 9;
    }
  }

  .project-detail__nav {
    margin-top: var(--space-l);
    padding-top: var(--space-m);
    border-top: 1px solid var(--bone);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-m);
    align-items: center;
  }

  .project-detail__nav-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: var(--ink);
  }

  .project-detail__nav-link:hover {
    color: var(--accent);
  }

  .project-detail__nav-link--next {
    text-align: right;
    align-items: flex-end;
  }

  .project-detail__nav-link--index {
    text-align: center;
    align-items: center;
  }

  .project-detail__nav-name {
    font-size: var(--t-body-m);
    font-weight: 400;
  }

  @media (max-width: 720px) {
    .project-detail__hero {
      aspect-ratio: 4 / 3;
      max-height: 60vh;
    }
    .project-detail__meta {
      grid-template-columns: 1fr 1fr;
    }
    .project-detail__section {
      padding: var(--space-m);
    }
    .project-detail__gallery {
      grid-template-columns: 1fr;
    }
    .project-detail__nav {
      grid-template-columns: 1fr;
      gap: var(--space-s);
    }
    .project-detail__nav-link--next {
      text-align: left;
      align-items: flex-start;
    }
    .project-detail__nav-link--index {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
