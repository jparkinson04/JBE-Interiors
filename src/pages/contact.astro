---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — JBE Interiors">
  <section class="contact">
    <div class="contact__inner">
      <header class="contact__header">
        <p class="eyebrow">Contact</p>
        <h1>Let&rsquo;s talk.</h1>
        <p class="contact__lead">
          For new project enquiries, questions, or to discuss a brief &mdash;
          get in touch directly.
        </p>
      </header>

      <div class="contact__primary">
        <a href="tel:+441302322202" class="contact__phone" aria-label="Call 01302 322 202">
          01302&nbsp;322&nbsp;202
        </a>
        <a href="mailto:jason@jbeinteriors.com" class="contact__email">
          jason@jbeinteriors.com
        </a>
      </div>

      <hr class="contact__rule" />

      <dl class="contact__meta">
        <div>
          <dt class="eyebrow">Direct</dt>
          <dd class="contact__meta-primary">Jason Beedle</dd>
          <dd class="contact__meta-secondary">Managing Director</dd>
        </div>
        <div>
          <dt class="eyebrow">Studio</dt>
          <dd class="contact__meta-primary">305 Churchway</dd>
          <dd class="contact__meta-secondary">Doncaster, DN1&nbsp;2TB</dd>
        </div>
        <div>
          <dt class="eyebrow">Hours</dt>
          <dd class="contact__meta-primary">Mon&ndash;Fri, 8:30am&ndash;6pm</dd>
          <dd class="contact__meta-secondary">Site visits by appointment</dd>
        </div>
      </dl>

      <hr class="contact__rule" />

      <nav class="contact__social" aria-label="Social channels">
        <a href="https://www.instagram.com/jbeinteriorsltd/" target="_blank" rel="noopener noreferrer">
          Instagram&nbsp;&rarr;
        </a>
        <span class="contact__social-divider" aria-hidden="true"></span>
        <a href="https://www.linkedin.com/company/jbe-interiors/" target="_blank" rel="noopener noreferrer">
          LinkedIn&nbsp;&rarr;
        </a>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    background: var(--ink);
    color: var(--paper);
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-l);
  }

  .contact__inner {
    width: 100%;
    max-width: 820px;
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    text-align: center;
  }

  .contact__header .eyebrow {
    color: color-mix(in srgb, var(--paper) 55%, transparent);
  }

  .contact__header h1 {
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--paper);
    margin-top: var(--space-s);
  }

  .contact__lead {
    margin: var(--space-s) auto 0;
    font-size: var(--t-body-l);
    color: color-mix(in srgb, var(--paper) 65%, transparent);
    line-height: var(--lh-body);
    max-width: 44ch;
  }

  /* Primary CTA block — phone is the centrepiece. Generous margin
     above sets it apart as the page's anchor; email follows tight. */
  .contact__primary {
    margin-top: var(--space-l);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-s);
  }

  .contact__phone {
    font-family: var(--font-serif);
    font-size: clamp(44px, 6vw, 76px);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--paper);
    display: inline-block;
  }

  .contact__phone:hover,
  .contact__email:hover,
  .contact__social a:hover {
    color: var(--accent);
  }

  .contact__email {
    font-size: var(--t-body-l);
    color: var(--paper);
    border-bottom: 1px solid color-mix(in srgb, var(--paper) 22%, transparent);
    padding-bottom: 2px;
  }

  .contact__rule {
    margin: var(--space-l) auto;
    width: 100%;
    max-width: 720px;
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--paper) 14%, transparent);
  }

  /* Three meta columns in one tight row — like a business card's
     printed details. Eyebrow label above two short lines of value. */
  .contact__meta {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-l);
    text-align: left;
  }

  .contact__meta > div {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .contact__meta dt {
    margin: 0;
    color: color-mix(in srgb, var(--paper) 55%, transparent);
    margin-bottom: var(--space-xs);
  }

  .contact__meta dd {
    margin: 0;
  }

  .contact__meta-primary {
    font-size: var(--t-body-m);
    color: var(--paper);
    line-height: 1.4;
  }

  .contact__meta-secondary {
    font-size: var(--t-body-s);
    color: color-mix(in srgb, var(--paper) 55%, transparent);
    line-height: 1.4;
  }

  .contact__social {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-m);
    font-size: var(--t-body-m);
  }

  .contact__social a {
    color: var(--paper);
  }

  .contact__social-divider {
    width: 1px;
    height: 14px;
    background: color-mix(in srgb, var(--paper) 22%, transparent);
  }

  @media (max-width: 720px) {
    .contact__inner {
      padding-inline: var(--grid-margin);
    }
    .contact__meta {
      grid-template-columns: 1fr;
      gap: var(--space-m);
      text-align: center;
    }
    .contact__meta > div {
      align-items: center;
    }
  }
</style>
