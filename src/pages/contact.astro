---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — JBE Interiors">
  <section class="contact">
    <figure class="contact__image" aria-hidden="true">
      <img
        src="/images/projects/sunday-in-brooklyn/gallery-9.jpg"
        alt=""
        width="1800"
        height="1200"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <figcaption class="contact__image-caption">
        Sunday in Brooklyn, James Street
      </figcaption>
    </figure>

    <div class="contact__panel">
      <div class="contact__inner">
        <header class="contact__header">
          <p class="eyebrow">Contact</p>
          <h1>Let&rsquo;s talk.</h1>
        </header>

        <div class="contact__primary">
          <a href="tel:+441302322202" class="contact__phone" aria-label="Call 01302 322 202">
            01302&nbsp;322&nbsp;202
          </a>
          <a href="mailto:jason@jbeinteriors.com" class="contact__email">
            jason@jbeinteriors.com
          </a>
        </div>

        <dl class="contact__meta">
          <div class="contact__meta-col">
            <dt class="eyebrow">Address</dt>
            <dd class="contact__meta-primary">305 Churchway</dd>
            <dd class="contact__meta-secondary">Doncaster, DN1&nbsp;2TB</dd>
            <dd class="contact__meta-secondary">Mon&ndash;Fri, 8:30am&ndash;6pm</dd>
          </div>

          <div class="contact__meta-col">
            <dt class="eyebrow">Follow</dt>
            <dd class="contact__meta-primary">
              <a
                class="contact__social-link"
                href="https://www.instagram.com/jbeinteriorsltd/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram — @jbeinteriorsltd"
              >
                <svg class="contact__social-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                </svg>
                <span>@jbeinteriorsltd</span>
              </a>
            </dd>
            <dd class="contact__meta-primary">
              <a
                class="contact__social-link"
                href="https://www.linkedin.com/company/jbe-interiors/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn — JBE Interiors"
              >
                <svg class="contact__social-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.26 2.37 4.26 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
                </svg>
                <span>JBE Interiors</span>
              </a>
            </dd>
          </div>
        </dl>

        <a
          class="contact__map-box"
          href="https://maps.app.goo.gl/tEbNqLE3zKFSizvM8"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open the JBE Interiors location on Google Maps"
        >
          <iframe
            class="contact__map"
            src="https://www.google.com/maps?q=305+Churchway,+Doncaster,+DN1+2TB&output=embed"
            title="JBE Interiors — 305 Churchway, Doncaster, DN1 2TB"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Editorial split: a full-bleed architectural photograph on the left,
     a clean paper-toned panel of contact information on the right. Ties
     the page back to the work and replaces the old monolithic dark slab. */
  .contact {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    /* svh locks the section to the smallest viewport state (mobile
       address bar visible) so the image doesn't reshape when the
       browser chrome retracts. */
    min-height: clamp(560px, 70vh, 720px);
    min-height: clamp(560px, 70svh, 720px);
    background: var(--paper);
  }

  /* Pull the image edge-to-edge of the viewport on the left, ignoring
     the BaseLayout's max-width / margin so it feels architectural rather
     than boxed. */
  .contact__image {
    position: relative;
    margin: 0;
    overflow: hidden;
    background: var(--ink);
  }

  .contact__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Map box sits in the right panel below the meta grid. Click anywhere
     on it to open the location in Google Maps. */
  .contact__map-box {
    display: block;
    width: 100%;
    height: 220px;
    overflow: hidden;
    background: var(--stone);
    border-left: 2px solid var(--accent);
    position: relative;
  }

  .contact__map {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    /* Desaturate slightly so the Google embed reads in the
       warm-monochrome palette of the page. */
    filter: grayscale(0.6) contrast(0.95);
    pointer-events: none;
  }

  .contact__image-caption {
    position: absolute;
    bottom: var(--space-m);
    left: var(--space-m);
    font-size: var(--t-eyebrow);
    font-weight: 500;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--paper);
    background: rgba(17, 17, 17, 0.7);
    padding: 6px 10px;
  }

  .contact__panel {
    background: var(--paper);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-l);
  }

  /* All content centred inside the panel and held to a comfortable
     reading column wide enough for a 3-column meta row. */
  .contact__inner {
    width: 100%;
    max-width: 600px;
    padding-inline: var(--space-l);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-l);
  }

  .contact__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .contact__header .eyebrow {
    color: var(--slate);
  }

  .contact__header h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
  }

  /* Phone + email centred and tight, sitting as the primary action. */
  .contact__primary {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-s);
  }

  .contact__phone {
    font-family: var(--font-serif);
    font-size: clamp(32px, 3.8vw, 52px);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--ink);
    display: inline-block;
  }

  .contact__phone:hover,
  .contact__email:hover,
  .contact__social-link:hover {
    color: var(--accent);
  }

  .contact__email {
    font-size: var(--t-body-m);
    color: var(--ink);
    border-bottom: 1px solid var(--bone);
    padding-bottom: 2px;
  }

  /* Two meta blocks side-by-side — Studio and Follow — with generous
     column gap so the two sit as a balanced pair. */
  .contact__meta {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-xl);
    width: 100%;
  }

  .contact__meta-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .contact__meta dt {
    margin: 0 0 var(--space-xs);
    color: var(--slate);
  }

  .contact__meta dd {
    margin: 0;
  }

  .contact__meta-primary {
    font-size: var(--t-body-m);
    color: var(--ink);
    line-height: 1.5;
  }

  .contact__meta-secondary {
    font-size: var(--t-body-s);
    color: var(--slate);
    line-height: 1.5;
  }

  .contact__social-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
    line-height: 1;
  }

  .contact__social-icon {
    flex-shrink: 0;
    color: inherit;
  }

  @media (max-width: 960px) {
    .contact {
      grid-template-columns: 1fr;
    }
    .contact__image {
      aspect-ratio: 16 / 10;
      min-height: 0;
    }
    .contact__panel {
      padding-block: var(--space-l);
    }
    .contact__inner {
      max-width: 640px;
      padding-inline: var(--grid-margin);
    }
  }

  /* Below 480px the two meta columns get too narrow — drop to one. */
  @media (max-width: 480px) {
    .contact__meta {
      grid-template-columns: 1fr;
      gap: var(--space-m);
    }
  }
</style>
