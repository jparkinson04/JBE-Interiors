---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — JBE Interiors">
  <section class="contact">
    <div class="contact__inner">
      <header class="contact__header">
        <p class="eyebrow">Contact</p>
        <h1>Let&rsquo;s talk.</h1>
        <p class="contact__lead">
          For new project enquiries, questions, or to discuss a brief &mdash;
          get in touch directly. We respond within one working day.
        </p>
      </header>

      <div class="contact__card">
        <div class="contact__col">
          <p class="eyebrow">Direct</p>
          <p class="contact__name">Jason Beedle</p>
          <p class="contact__role">Managing Director</p>
          <a href="tel:+441302322202" class="contact__phone" aria-label="Call 01302 322 202">
            01302&nbsp;322&nbsp;202
          </a>
          <a href="mailto:jason@jbeinteriors.com" class="contact__email">
            jason@jbeinteriors.com
          </a>
        </div>

        <div class="contact__col">
          <p class="eyebrow">Studio</p>
          <address class="contact__address">
            JBE Interiors Ltd<br />
            305 Churchway<br />
            Doncaster, DN1&nbsp;2TB
          </address>
          <p class="contact__hours">
            Mon&ndash;Fri, 8:30am&ndash;6pm.<br />
            Site visits by appointment.
          </p>
        </div>

        <div class="contact__col">
          <p class="eyebrow">Follow</p>
          <ul class="contact__social" role="list">
            <li>
              <a href="https://www.instagram.com/jbeinteriorsltd/" target="_blank" rel="noopener noreferrer">
                Instagram&nbsp;&rarr;
              </a>
              <span class="contact__handle">@jbeinteriorsltd</span>
            </li>
            <li>
              <a href="https://www.linkedin.com/company/jbe-interiors/" target="_blank" rel="noopener noreferrer">
                LinkedIn&nbsp;&rarr;
              </a>
              <span class="contact__handle">JBE Interiors</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    background: var(--ink);
    color: var(--paper);
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    padding-block: var(--space-xl);
  }

  .contact__inner {
    width: 100%;
    max-width: 1180px;
    margin-inline: auto;
    padding-inline: var(--grid-margin);
  }

  .contact__header {
    text-align: center;
    margin-bottom: var(--space-l);
    max-width: 720px;
    margin-inline: auto;
  }

  .contact__header .eyebrow {
    color: color-mix(in srgb, var(--paper) 60%, transparent);
  }

  .contact__header h1 {
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 300;
    letter-spacing: var(--ls-display);
    line-height: var(--lh-display);
    color: var(--paper);
    margin-top: var(--space-s);
  }

  .contact__lead {
    margin-top: var(--space-m);
    font-size: var(--t-body-l);
    color: color-mix(in srgb, var(--paper) 70%, transparent);
    line-height: var(--lh-body);
    max-width: 52ch;
    margin-inline: auto;
  }

  .contact__card {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    padding: var(--space-l) 0;
    border-top: 1px solid color-mix(in srgb, var(--paper) 18%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--paper) 18%, transparent);
  }

  .contact__col {
    padding: var(--space-s) var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    border-left: 1px solid color-mix(in srgb, var(--paper) 12%, transparent);
  }

  .contact__col:first-child {
    border-left: 0;
    padding-left: 0;
  }

  .contact__col:last-child {
    padding-right: 0;
  }

  .contact__col .eyebrow {
    color: color-mix(in srgb, var(--paper) 60%, transparent);
    margin-bottom: var(--space-s);
  }

  .contact__name {
    font-size: var(--t-body-l);
    color: var(--paper);
  }

  .contact__role {
    font-size: var(--t-body-s);
    color: color-mix(in srgb, var(--paper) 60%, transparent);
    margin-bottom: var(--space-m);
  }

  .contact__phone {
    font-family: var(--font-serif);
    font-size: clamp(32px, 3.6vw, 52px);
    font-weight: 400;
    letter-spacing: -0.015em;
    line-height: 1.0;
    color: var(--paper);
    margin-bottom: var(--space-s);
  }

  .contact__phone:hover,
  .contact__email:hover,
  .contact__social a:hover {
    color: var(--accent);
  }

  .contact__email {
    font-size: var(--t-body-m);
    color: var(--paper);
    border-bottom: 1px solid color-mix(in srgb, var(--paper) 25%, transparent);
    padding-bottom: 2px;
    align-self: flex-start;
  }

  .contact__address {
    font-style: normal;
    font-size: var(--t-body-l);
    line-height: var(--lh-body);
    color: var(--paper);
  }

  .contact__hours {
    margin-top: var(--space-m);
    font-size: var(--t-body-m);
    color: color-mix(in srgb, var(--paper) 65%, transparent);
    line-height: var(--lh-body);
  }

  .contact__social {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .contact__social li {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .contact__social a {
    font-size: var(--t-body-l);
    color: var(--paper);
    font-weight: 400;
  }

  .contact__handle {
    font-size: var(--t-body-s);
    color: color-mix(in srgb, var(--paper) 55%, transparent);
  }

  @media (max-width: 900px) {
    .contact__card {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .contact__col {
      border-left: 0;
      border-top: 1px solid color-mix(in srgb, var(--paper) 12%, transparent);
      padding: var(--space-l) 0;
    }
    .contact__col:first-child {
      border-top: 0;
      padding-top: var(--space-s);
    }
    .contact__col:last-child {
      padding-bottom: var(--space-s);
    }
  }
</style>
