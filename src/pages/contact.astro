---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — JBE Interiors">
  <section class="contact">
    <div class="contact__inner">
      <header class="contact__header">
        <p class="eyebrow">Contact</p>
        <h1>Let&rsquo;s talk.</h1>
      </header>

      <div class="contact__primary">
        <a href="tel:+441302322202" class="contact__phone" aria-label="Call 01302 322 202">
          01302&nbsp;322&nbsp;202
        </a>
        <a href="mailto:jason@jbeinteriors.com" class="contact__email">
          jason@jbeinteriors.com
        </a>
      </div>

      <hr class="contact__rule" />

      <dl class="contact__meta">
        <div class="contact__meta-col">
          <dt class="eyebrow">Direct</dt>
          <dd class="contact__meta-primary">Jason Beedle</dd>
          <dd class="contact__meta-secondary">Managing Director</dd>
        </div>

        <div class="contact__meta-col">
          <dt class="eyebrow">Studio</dt>
          <dd class="contact__meta-primary">305 Churchway</dd>
          <dd class="contact__meta-secondary">Doncaster, DN1&nbsp;2TB</dd>
          <dd class="contact__meta-secondary">Mon&ndash;Fri, 8:30am&ndash;6pm</dd>
        </div>

        <div class="contact__meta-col">
          <dt class="eyebrow">Follow</dt>
          <dd class="contact__meta-primary">
            <a
              class="contact__social-link"
              href="https://www.instagram.com/jbeinteriorsltd/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram — @jbeinteriorsltd"
            >
              <svg class="contact__social-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
              </svg>
              <span>@jbeinteriorsltd</span>
            </a>
          </dd>
          <dd class="contact__meta-primary">
            <a
              class="contact__social-link"
              href="https://www.linkedin.com/company/jbe-interiors/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn — JBE Interiors"
            >
              <svg class="contact__social-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.26 2.37 4.26 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
              </svg>
              <span>JBE Interiors</span>
            </a>
          </dd>
        </div>
      </dl>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    background: var(--ink);
    color: var(--paper);
    min-height: calc(100vh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-m);
  }

  .contact__inner {
    width: 100%;
    max-width: 920px;
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    text-align: center;
  }

  .contact__header .eyebrow {
    color: color-mix(in srgb, var(--paper) 55%, transparent);
  }

  .contact__header h1 {
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 300;
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--paper);
    margin-top: var(--space-xs);
  }

  /* Primary CTA — phone is the centerpiece. Email sits tight below. */
  .contact__primary {
    margin-top: var(--space-m);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .contact__phone {
    font-family: var(--font-serif);
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--paper);
    display: inline-block;
  }

  .contact__phone:hover,
  .contact__email:hover,
  .contact__social-link:hover {
    color: var(--accent);
  }

  .contact__email {
    font-size: var(--t-body-m);
    color: var(--paper);
    border-bottom: 1px solid color-mix(in srgb, var(--paper) 22%, transparent);
    padding-bottom: 2px;
  }

  .contact__rule {
    margin: var(--space-m) auto;
    width: 100%;
    max-width: 720px;
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--paper) 14%, transparent);
  }

  /* Three meta columns aligned and tight. Each column has the eyebrow
     label followed by a primary line and any secondary lines. Follow
     column houses Instagram and LinkedIn with their icon marks. */
  .contact__meta {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-l);
    text-align: left;
  }

  .contact__meta-col {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .contact__meta dt {
    margin: 0;
    color: color-mix(in srgb, var(--paper) 55%, transparent);
    margin-bottom: var(--space-xs);
  }

  .contact__meta dd {
    margin: 0;
  }

  .contact__meta-primary {
    font-size: var(--t-body-m);
    color: var(--paper);
    line-height: 1.4;
  }

  .contact__meta-secondary {
    font-size: var(--t-body-s);
    color: color-mix(in srgb, var(--paper) 55%, transparent);
    line-height: 1.4;
  }

  .contact__social-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--paper);
    line-height: 1;
  }

  .contact__social-icon {
    flex-shrink: 0;
    color: inherit;
  }

  @media (max-width: 720px) {
    .contact__meta {
      grid-template-columns: 1fr;
      gap: var(--space-m);
      text-align: center;
    }
    .contact__meta-col {
      align-items: center;
    }
  }
</style>
